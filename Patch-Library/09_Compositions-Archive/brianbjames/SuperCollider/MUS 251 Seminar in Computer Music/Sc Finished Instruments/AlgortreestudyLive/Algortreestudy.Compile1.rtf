\f1\fs18 \cf2 // MAKE GUI Function -- the tilde is necessary!\cf0 \
~lsBandPass = \{ \cf4 var\cf0  out=0, in=0;\
	\cf4 var\cf0  myWind, \
		loSlider, hiSlider, rqSlider, \
		rangeSlider, lagSlider, \
		doUpdate, memSliders, \
		inst;\
\cf2 // function to call when you update the rangeslider or the high and lo sliders\cf0 \
\cf2 // -- it sets them to the same values\cf0 \
doUpdate = \{	\cf4 arg\cf0  inLo, inHi;\
		\cf4 var\cf0  newLo, newHi;\
		if(inLo<inHi, \{newLo=inLo; newHi=inHi\}, \{newLo=inHi; newHi=inLo\});\
		rangeSlider.lo_(newLo);\
		rangeSlider.hi_(newHi);\
		loSlider.value = round(\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ).map(newLo), 1);\
		hiSlider.value = round(\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ).map(newHi));			\};\
		\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural\pardirnatural

\fs42 \cf2 //GUI for Bandpass
\fs18 \cf0 \
myWind = \cf4 SCWindow\cf0 .new(\cf3 "BandPass"\cf0 , \cf4 Rect\cf0 (700, 130, 480, 280));\
myWind.view.decorator = \cf4 FlowLayout\cf0 (myWind.view.bounds);\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural\pardirnatural
\cf2 // on close free the synth effect\cf0 \
myWind.onClose_(\{inst.free;\});\
rangeSlider = \cf4 SCRangeSlider\cf0 (myWind, \cf4 Rect\cf0 (0, 0, 470, 120))\
	.action_(\{\cf4 arg\cf0  me; doUpdate.value(me.lo.value, me.hi.value)\})\
	.knobColor_(\cf4 Color\cf0 .black);\
myWind.view.decorator.nextLine;\
\cf2 // this slider sets the synth low cutoff value\cf0 \
loSlider = \cf4 EZSlider\cf0 (myWind, 400 @ 24, \cf3 "Low Cutoff"\cf0 ,\
	\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ),\{\
			\cf4 |ez|\cf0  inst.set(\cf5 \\lo\cf0 , ez.value); \
			rangeSlider.lo_(\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ).unmap(ez.value));\
		\}, 20);\
myWind.view.decorator.nextLine;\
\cf2 // this slider sets the synth high cutoff value\cf0 \
hiSlider = \cf4 EZSlider\cf0 (myWind, 400 @ 24, \cf3 "High Cutoff"\cf0 , \
	\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ),\{\
			\cf4 |ez|\cf0  inst.set(\cf5 \\hi\cf0 , ez.value); \
			rangeSlider.hi_(\cf4 ControlSpec\cf0 .specs.at(\cf5 \\freq\cf0 ).unmap(ez.value));\
		\}, 20000);		\
myWind.view.decorator.nextLine;\
\cf2 // resonance for the filter\cf0 \
rqSlider = \cf4 EZSlider\cf0 (myWind, 200 @ 24, \cf3 "Rez"\cf0 , \
	\cf4 ControlSpec\cf0 (0.001, 2, \cf5 \\exp\cf0 , 0, 0.707),\
	\{\cf4 |ez|\cf0  inst.set(\cf5 \\rq\cf0 , ez.value); \}, 0.707, labelWidth: 40, numberWidth: 40);\
\cf2 // lag of the controls -- so it glides evenly\cf0 \
lagSlider = \cf4 EZSlider\cf0 (myWind, 200 @ 24, \cf3 "Lag"\cf0 , \
	\cf4 ControlSpec\cf0 (0, 20, \cf5 \\linear\cf0 , 0, 5),\
	\{\cf4 |ez|\cf0  inst.set(\cf5 \\lagTime\cf0 , ez.value); \}, 5, labelWidth: 40, numberWidth: 40).round_(0.01);\
myWind.view.decorator.nextLine;\
\
\cf2 // this is my tricky way of making an array of buttons and rangesliders.\cf0 \
\cf2 // the if statement checks the fill counter ("i") and sees if it's even or odd, and\cf0 \
\cf2 // puts a button or rangeslider accordingly\cf0 \
memSliders = \cf4 Array\cf0 .fill(8, \{\cf4 |i|\cf0 \
	if(i%2==0, \
		\{\cf4 SCButton\cf0 (myWind, \cf4 Rect\cf0 (0, 0, 24, 24))\
			.states_([[(i+1).asString]])\
			.action_(\{doUpdate.value(memSliders[i+1].lo.value, memSliders[i+1].hi.value);\})\
			\},\
		\{\cf4 SCRangeSlider\cf0 (myWind, \cf4 Rect\cf0 (0, 0, 200, 24)).knobColor_(\cf4 Color\cf0 .black)\}\
	\
	)\});\
myWind.front;\
\
