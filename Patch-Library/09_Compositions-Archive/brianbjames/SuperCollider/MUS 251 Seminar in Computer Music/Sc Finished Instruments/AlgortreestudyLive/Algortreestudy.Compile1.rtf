\fs20 \cf2 /* This is a helper function, it creates the individual channel strips' \
	GUI, analysis node on the server, and update routine.\
	chanNumber: this strip's number.\
	meterWind: parent window to draw to\
	inBus: input bus index.\
	meterGroup: group on which to put the analysis synth node */\cf0 \
~makeMeter = \{ \cf4 arg\cf0  chanNumber=0, meterWind, inBus, meterGroup;\
	\cf4 var\cf0  stripView, peakBox, rmsBox, rSlider, sSlider, pSlider, clipWarn,\
				stripBus, stripBtn, inst, proc, refreshRate=0.1,\
				hx=10, hw=40, mx=40, mw=170, nx=330, nw=70, yOffset, chanHeight=40;\
		\cf2 // how far down to begin drawing this on the window\cf0 \
	yOffset = (chanNumber*chanHeight)+460;\
		\cf2 // Control bus for analysis data (on default server)\cf0 \
	stripBus = \cf4 Bus\cf0 .control(numChannels: 4);\
		\cf2 // analysis synth node.  writes to control bus. \cf0 \
	inst = \cf4 Synth\cf0 (\cf3 "seldonmeter"\cf0 , [\cf5 \\out\cf0 , stripBus.index, \cf5 \\in\cf0 , inBus, \cf5 \\gain\cf0 , 1], meterGroup);
