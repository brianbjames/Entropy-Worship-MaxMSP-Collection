\cf2 //	ENVELOPES\cf0 \
\cf2 /*	Env.new(levels, times, curves, releaseNode, loopNode)\

\f1\b 	levels
\f0\b0  - an array of levels. The first level is the initial value of the envelope.\
	
\f1\b times
\f0\b0  - an array of durations of segments in seconds. There should be\
	one fewer duration than there are levels.\
	
\f1\b curve
\f0\b0  - this parameter determines the shape of the envelope segments.\
	
\f1\b releaseNode
\f0\b0  - an Integer or nil. If not nil, the envelope will sustain at the releaseNode until released.\
	
\f1\b loopNode
\f0\b0  - an Integer or nil. If not nil the sustain portion will loop from the releaseNode to the loop node.\
*/\cf0 \
\cf3 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],\cf4 'linear'\cf0 ,\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;  \cf2 // plot in a GUI window\cf0 \
\cf2 // levels of an 'exponential' Env must all be non-zero!!\cf0 \
\cf3 Env\cf0 .new([0.25,0.5,0.1],[1.0,0.5],\cf4 'exponential'\cf0 ,\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;\
\cf2 // sinusoidal curve\cf0 \
\cf3 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],\cf4 'sine'\cf0 ,\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;\
\cf2 // the slope of curves can be specified by numbers\cf0 \
\cf3 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[4,1],\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;\
\cf3 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[4,-1],\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;\
\cf3 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[-4,1],\cf3 nil\cf0 ,\cf3 nil\cf0 ).plot;\
\
\cf2 /* ENVELOPE GENERATOR: EnvGen\
EnvGen.ar(envelope, gate, levelScale, levelBias, timeScale, doneAction)\

\f1\b doneAction
\f0\b0  -\
	 the doneAction arg allows you to make the EnvGen end the \
	 Synth it is part of.  The most common doneActions are:\
	doneAction = 0   do nothing when the envelope has ended.\
 	doneAction = 1   pause the synth running, it is still resident.\
 	doneAction = 2   remove the synth and deallocate it.\
*/\cf0 \
\
\cf2 // make an envelope and use it in an EnvGen that multiplies the output of a SinOsc,  controlling its amplitude\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 \\envTest\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env; \
	env = \cf3 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf4 'linear'\cf0 ,\cf3 nil\cf0 ,\cf3 nil\cf0 );\
	\cf3 Out\cf0 .ar(out,\
		\cf3 SinOsc\cf0 .ar(800,0,\
		\cf2 // note "keyword" style of supplying the doneAction arg --  args can be specified in any order, identified by 'name:'\cf0 \
			\cf3 EnvGen\cf0 .kr(env, doneAction: 2)))   \cf2 // env controls amplitude\cf0 \
\}).play;\
)\
\
\
(\cf2 // two envelopes, one for amplitude, one for frequency\cf0 \
\cf3 SynthDef\cf0 (\cf5 "twoEnvs"\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  ampEnv, freqEnv, sig;\
	ampEnv = \cf3 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf4 'linear'\cf0 );\
	\cf2 // try changing the curves of freqEnv\cf0 \
	freqEnv = \cf3 Env\cf0 .new([200,600,400],[1.0,0.5],[4,1]);\
	sig = \cf3 SinOsc\cf0 .ar(\cf3 EnvGen\cf0 .kr(freqEnv),\
						0,\cf3 EnvGen\cf0 .kr(ampEnv, doneAction: 2));\
	\cf3 Out\cf0 .ar(out,sig)\
\}).play\
)\
\
\cf2 // two voices, each with both amplitude and frequency\cf0 \
\cf2 //		 envelopes - the envelopes are stored in arrays\cf0 \
\cf2 // this is a model for the instrument in the assignment\cf0 \
(\
\cf3 SynthDef\cf0 (\cf5 "duet"\cf0 ,\{ \cf3 arg\cf0  out;\
	\cf3 var\cf0  ampEnvelopes, freqEnvelopes;\
	ampEnvelopes = \
		[\
			\cf3 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf4 'linear'\cf0 ),\
			\cf3 Env\cf0 .new([0.0,0.5,0.0],[0.5,1.0],\cf4 'linear'\cf0 )\
		];\
	freqEnvelopes = \
		[\
			\cf3 Env\cf0 .new([200,600,400],[1.0,0.5],[4,1]),\
			\cf3 Env\cf0 .new([300,602,200],[1.0,0.5],[4,1])\
		];\
	\cf3 Out\cf0 .ar(out,\
		\cf3 SinOsc\cf0 .ar(\cf3 EnvGen\cf0 .kr(freqEnvelopes.at(0)),\
				0,\cf3 EnvGen\cf0 .kr(ampEnvelopes.at(0),doneAction: 2))\
		+				\cf2 // mixing the two oscillators\cf0 \
  		\cf3 SinOsc\cf0 .ar(\cf3 EnvGen\cf0 .kr(freqEnvelopes.at(1)),\
  				0,\cf3 EnvGen\cf0 .kr(ampEnvelopes.at(1),doneAction: 2)))\
 \}).play\
)\
\
( \cf2 // same, but stereo, instead of mixed  -- \cf0 \
\cf3 SynthDef\cf0 (\cf5 "duet"\cf0 ,\{ \cf3 arg\cf0  out;\
	\cf3 var\cf0  ampEnvelopes, freqEnvelopes;\
	ampEnvelopes = \
		[\
			\cf3 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf4 'linear'\cf0 ),\
			\cf3 Env\cf0 .new([0.0,0.5,0.0],[0.5,1.0],\cf4 'linear'\cf0 )\
		];\
	freqEnvelopes = \
		[\
			\cf3 Env\cf0 .new([200,600,400],[1.0,0.5],[4,1]),\
			\cf3 Env\cf0 .new([300,602,200],[1.0,0.5],[4,1])\
		];\
	\cf3 Out\cf0 .ar(out,\
		\cf2 // two oscillators in an Array\cf0 \
		[ \cf3 SinOsc\cf0 .ar(\cf3 EnvGen\cf0 .kr(freqEnvelopes.at(0)),0,\
			\cf3 EnvGen\cf0 .kr(ampEnvelopes.at(0), doneAction: 2)),\
		 \cf3 SinOsc\cf0 .ar(\cf3 EnvGen\cf0 .kr(freqEnvelopes.at(1)),0,\
			\cf3 EnvGen\cf0 .kr(ampEnvelopes.at(1), doneAction: 2))]\
  		)\
 \}).play\
)\
\
(\cf2 // other convenient envelope creation methods \cf0 \
\cf3 SynthDef\cf0 (\cf5 "envTests"\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env;\
	\cf2 //	*perc(attackTime, releaseTime, peakLevel, curve)\cf0 \
	\cf2 //	env = Env.perc(0.0,0.35,0.5,-1);\cf0 \
	\cf2 //	*triangle(duration, level)\cf0 \
	\cf2 //	env = Env.triangle(1.0,0.8);\cf0 \
	\cf2 //	*linen(attackTime, sustainTime, releaseTime, sustainLevel)\cf0 \
		env = \cf3 Env\cf0 .linen(0.1,2.5,0.5,0.8);\
	\cf3 Out\cf0 .ar(out,\
		\cf3 SinOsc\cf0 .ar(500,0,\cf3 EnvGen\cf0 .kr(env,doneAction: 2)))\
\}).play\
)\
\
\cf2 /* the Env methods 'adsr' and 'asr' create envelopes with\
 sustain segments,which stay at the sustain level \
	until explicitly released by the Synth that plays it:\
	\
	*adsr(attackTime, decayTime, sustainLevel,  \
							releaseTime, peakLevel, curve)\
	*asr(attackTime, sustainLevel,  releaseTime, peakLevel, curve)\
	\
	to control the release, the Synth must have an arg called 'gate'\
	which is open (value=1) when the Synth starts */\cf0 \
(	\
a = \cf3 SynthDef\cf0 (\cf5 "susEnvTests"\cf0 ,\{ \cf3 arg\cf0  out=0, gate=1;\
	\cf3 var\cf0  env;\
	env = \cf3 Env\cf0 .adsr(0.1, 0.2, 0.25, 0.8, 1, -4);\
	\cf3 Out\cf0 .ar(out,\
		\cf2 // the 'gate' arg controls the EnvGen release \cf0 \
		\cf3 SinOsc\cf0 .ar(500,0,\cf3 EnvGen\cf0 .kr(env,gate,doneAction: 2)))\
\}).play;\
)\
\cf2 // the method 'release' will set the 'gate' arg to 0, initiating the\cf0 \
\cf2 // release time segment\cf0 \
a.release;\
\
\cf2 //	EnvGen's 'gate' can be modulated to retrigger an Env\cf0 \
(	\cf2 // create a repeating note, \cf0 \
\cf2 //	using a pulse wave to gate and release EnvGen\cf0 \
a = \cf3 SynthDef\cf0 (\cf5 "repTest"\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env, sig, speed, gate;  \cf2 // this 'gate' is a variable, so it can't be used to free the Synth\cf0 \
	\cf2 // 
\f3\fs24 *
\f2\b adsr(attackTime, decayTime, sustainLevel,  releaseTime, peakLevel, curve)
\f0\b0\fs36 \cf0 \
	env = \cf3 Env\cf0 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
	\cf2 // MouseX-position controls gate speed\cf0 \
	\cf2 // 
\f2\b\fs24 LFPulse.ar(freq, iphase,width, mul, add)
\f0\b0\fs36 \cf0 \
	gate = \cf3 LFPulse\cf0 .ar(\cf3 MouseX\cf0 .kr(0.2, 10, \cf4 'exponential'\cf0 ),0, \
	\cf2 // MouseY controls pulse-width of gate\cf0 \
		\cf3 MouseY\cf0 .kr(0.01,0.99));	\cf2 //  \cf0 \
	sig = \cf3 SinOsc\cf0 .ar(300, 0, \cf3 EnvGen\cf0 .kr(env,gate));\
	\cf3 Out\cf0 .ar(out,sig)\
\}).play;\
)\
a.free;\
\cf2 // now, add use of levelScale and timeScale args to change the \cf0 \
\cf2 // loudness and time of the same envelope as it plays\cf0 \
(\
\cf3 SynthDef\cf0 (\cf5 "repTest"\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env, gate, sig, speed;\
	env = \cf3 Env\cf0 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
	\cf2 // MouseX-position controls gate speed\cf0 \
	speed = \cf3 MouseX\cf0 .kr(0.2, 20, \cf4 'exponential'\cf0 );\
	gate = \cf3 LFPulse\cf0 .kr(speed,0,0.5);\
	sig = \cf3 SinOsc\cf0 .ar(300, 0, \
		\cf3 EnvGen\cf0 .kr(env,gate, \
				levelScale: \cf3 MouseY\cf0 .kr(0,1),\
				timeScale: speed.reciprocal));\
	\cf3 Out\cf0 .ar(out,sig)\
\}).play;\
)\
