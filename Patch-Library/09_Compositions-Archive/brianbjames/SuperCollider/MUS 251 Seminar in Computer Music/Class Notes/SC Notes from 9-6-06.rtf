\f0\fs36 \cf0 (	\cf2 // two sine oscillators are mixed\cf0 \
\cf3 SynthDef\cf0 (\cf4 \\addSynth\cf0 ,\{ \cf3 arg\cf0  out=0; \cf2 // note that backslash+string is the same as "string"\cf0 \
	\cf3 Out\cf0 .ar(out,\
		\cf3 SinOsc\cf0 .ar(440,0,0.5)		\cf2 // args are freq, phase, and mul (amp)\cf0 \
		+				\cf2 //	Adding is Mixing !!\cf0 \
		\cf3 SinOsc\cf0 .ar(660,0,0.5));  \
\}).play;	 \cf2 // 'play' method of compiles a SynthDef then sends and starts a Synth in a single step\cf0 \
)\
\
\cf2 /* STEREO VERSION:  When an 
\f1\b Array
\f0\b0  is given as an input to a unit generator it causes an array of multiple copies of that unit generator to be made, each with a different value from the input array. This is called multichannel expansion.  Below, we get one SinOsc with freq=440 on the left (audio Bus = 0) and another SinOsc with freq=660 on the right (audio Bus = 1) */\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 \\stereoSines\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 Out\cf0 .ar(0,\cf3 SinOsc\cf0 .ar([440,660],0,0.5))\}).play;\
)\
\
\cf2 // Mix.fill(n,function) creates an array of n sound functions, then adds them -- try executing this one several times before stopping the sound with cmd-period...rrand = random range\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 \\sin4Mix\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 Out\cf0 .ar(out,\
		\cf3 Mix\cf0 .fill(4,\{ \cf3 SinOsc\cf0 .ar(rrand(440,660),0,0.1) \})\
	)\
\}).play;\
)\
\
\cf2 // using Line and XLine to control the 'freq' arg of oscillators\cf0 \
\cf2 // Line's args are:  start, end, dur\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 \\lineTest\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 Out\cf0 .ar(0,\cf3 SinOsc\cf0 .ar(\cf3 Line\cf0 .kr(100,8000,4),0,0.1))\
\}).play;\
)\
\
\cf2 // compare XLine, exponential control of frequency sounds linear\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 \\xLineTest\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 Out\cf0 .ar(0,\cf3 SinOsc\cf0 .ar(\cf3 XLine\cf0 .kr(100,8000,4),0,0.1))\
\}).play;\
)\
