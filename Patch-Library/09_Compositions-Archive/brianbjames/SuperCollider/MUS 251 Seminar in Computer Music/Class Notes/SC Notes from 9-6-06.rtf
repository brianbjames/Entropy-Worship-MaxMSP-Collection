\cf2 // other oscillators in SC3\cf0 \
\cf2 // Osc is a wavetable oscillator\cf0 \
(\
\cf3 Server\cf0 .default = \cf3 Server\cf0 .internal;	\cf2 // use the internal Server, so we can view the waveform\cf0 \
s = \cf3 Server\cf0 .default;\
s.waitForBoot(\{	\cf2 // this method boots the Server, and waits until it is ready to execute the Function\cf0 \
	b = \cf3 Buffer\cf0 .alloc(s, 512, 1);	\cf2 // creates a Buffer of 512 samples and 1 channel on s...a buffer is an area of memory, alloc allocates space\cf0 \
	b.bufnum;			\cf2 // the 'bufnum' method returns the Buffer's index\cf0 \
\});\
)\
\cf2 /* sine1 ( arg amplitudes,normalize=false,asWavetable=false,clearFirst=false); \
the sine1 method of Buffer creates a waveform that is the sum of a series of sinewave harmonics with amplitudes given by an Array of values passed to the arg "amplitudes"\
*/\cf0 \
b.sine1((1.0/[1,2,3,4,5,6]).postln).plot;  \
\cf2 /* 1.0 is divided by each member of the Array, creating a new Array - try other math functions, but remember that 1.0 is the maximum.....plot = show you the wavetable's plot\
*/\cf0 \
\
\cf2 // 	create a SynthDef called "help-Osc",  with arguments 'out' (an Audio Bus.index), and 'bufnum', a Buffer.index.\cf0 \
(\
\cf3 SynthDef\cf0 (\cf5 "help-Osc"\cf0 ,\{ \cf3 arg\cf0  out=0, bufnum=0, freq=200, amp=0.1;\
	\cf3 Out\cf0 .ar(out,\
	\cf2 //   Osc.ar(table, freq, phase, mul, add) -- an oscillator in which you provide the wavetable\cf0 \
		\cf3 Osc\cf0 .ar(bufnum, freq, 0, amp)	\cf2 // freq=200, phase=0, amp = 0.1\cf0 \
	)\
\}).load(s);		\cf2 // load the SynthDef to the 's' Server, which makes it ready to play.\cf0 \
)\
\cf2 //	now start the Synth by it's name, using arguments in the Array that follows the name and store the Synth instance in the environment variable 'x'\cf0 \
x = \cf3 Synth\cf0 (\cf5 "help-Osc"\cf0 ,[\cf4 \\out\cf0 , 0, \cf4 \\bufnum\cf0 , b.bufnum]);\
s.scope(2);	\cf2 // view the first two ouput channels\cf0 \
\cf2 // send messages to change the output chan assignment and freq\cf0 \
x.set(\cf5 "out"\cf0 ,1,\cf5 "freq"\cf0 ,800);\
x.set(\cf5 "out"\cf0 ,0,\cf5 "freq"\cf0 ,600);\
x.set(\cf5 "out"\cf0 ,1,\cf5 "freq"\cf0 ,400);\
\cf2 //	the 'free' message stops the Synth from playing, and erases it's object from the Server\cf0 \
x.free;\
\cf2 \
// Use the Ugens MouseX and MouseY to have parameters of a synth track the mouse position.  The arguments for these Ugens set low and high bounds corresponding to extreme edges of the screen.  This also introduces other SC Oscillators:  Saw, SyncSaw, Pulse, Blip\cf0 \
(\
\cf3 SynthDef\cf0 (\cf5 "test-Saw"\cf0 ,\{ \cf3 arg\cf0  freq=200, amp=0.1;\
	\cf3 Out\cf0 .ar(0, \
		\cf3 Saw\cf0 .ar([freq+\cf3 MouseX\cf0 .kr(-5,5), freq-\cf3 MouseX\cf0 .kr(-5,5)], \
			amp))\
\}).play;\
s.scope(2);	\cf2 // 'scope' message plays and displays the Synth\cf0 \
)\
\
(	\cf2 // SyncSaw (hard sync sawtooth wave) demonstrates aliasing\cf0 \
\cf3 SynthDef\cf0 (\cf5 "test-SyncSaw"\cf0 ,\{ \cf3 arg\cf0  out=0;\
	\cf3 Out\cf0 .ar(out,\
	\cf2 //	
\f2\b\fs30 SyncSaw.ar(ksyncFreq, ksawFreq, mul, add)
\f0\b0\fs36 \cf0 \
		 \cf3 SyncSaw\cf0 .ar(100, \cf3 Line\cf0 .kr(100, 8000, 12), 0.2) \
	)\
\}).play;\
s.scope(2)\
)\
\
(	\cf2 // control pulse-width ratio (duty-cycle) of pulse waves, creating phase-cancellation effects\cf0 \
\cf3 SynthDef\cf0 (\cf5 "test-Pulse"\cf0 ,\{ \cf3 arg\cf0  freq=200, amp=0.1;\
	\cf3 Out\cf0 .ar(0, \
		\cf2 // Pulse.ar(freq, width, mul, add)\cf0 \
		\cf3 Pulse\cf0 .ar(freq, [\cf3 MouseX\cf0 .kr(0,1),\cf3 MouseY\cf0 .kr(0,1)], amp))\
\}).play;\
s.scope(2);	\
)\
\
( \cf2 // Blip.ar(kfreq, knumharmonics, mul, add) -- Band Limited ImPulse generator. All harmonics have equal amplitude.\cf0 \
\cf3 SynthDef\cf0 (\cf5 "test-Blip"\cf0 ,\{ \cf3 arg\cf0  freq=200, amp=0.1;\
	\cf3 Out\cf0 .ar(0, \
		\cf3 Blip\cf0 .ar(freq, [\cf3 MouseX\cf0 .kr(1,100),\cf3 MouseY\cf0 .kr(1,100)], amp))\
