\f0\fs36 \cf0 ( \cf2 // WhiteNoise = equal power noise at all frequencies; PinkNoise  = noise spectrum drops 3 dB per octave; BrownNoise = 6 dB per octave drop; try substituting these in the instrument below\cf0 \
\cf3 SynthDef\cf0 (\cf5 "help-WhiteNoise"\cf0 , \{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env, gate, speed;\
	\cf3 Out\cf0 .ar(out, \
		env = \cf3 Env\cf0 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
		speed = \cf3 MouseX\cf0 .kr(0.1,20,\cf4 'exponential'\cf0 );\
		gate = \cf3 LFPulse\cf0 .kr(speed,0,\cf3 MouseY\cf0 .kr(0,1),0.25);\
		\cf3 WhiteNoise\cf0 .ar(\cf3 EnvGen\cf0 .kr(env,gate, \
				timeScale: speed.reciprocal))\
	)\
