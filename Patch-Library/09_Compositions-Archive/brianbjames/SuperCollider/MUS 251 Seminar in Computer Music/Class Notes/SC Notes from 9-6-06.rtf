( \cf2 // Impulse is good for triggering things -- it generates a single positive sample per freq cycle \cf0 \
\cf3 SynthDef\cf0 (\cf5 "help-WhiteNoise"\cf0 , \{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env, gate, speed;\
	\cf3 Out\cf0 .ar(out, \
		env = \cf3 Env\cf0 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
		speed = \cf3 MouseX\cf0 .kr(0.1,20,\cf4 'exponential'\cf0 );\
		\cf2 // 
\f2\b\fs24 Impulse.ar(freq, phase, mul, add)
\f0\b0\fs36 \cf0 \
		gate = \cf3 Impulse\cf0 .kr(speed);\
		\cf3 WhiteNoise\cf0 .ar(\cf3 EnvGen\cf0 .kr(env,gate, \
				levelScale: \cf3 MouseY\cf0 .kr(0,1),	\cf2 // controls amplitude of output level\cf0 \
				timeScale: speed.reciprocal))\
	)\
\}).play;\
s.scope(2)\
)\
\
( \cf2 // Dust is a random impulse generator, MouseX controls density of impulses\cf0 \
\cf3 SynthDef\cf0 (\cf5 "geigerCtr"\cf0 , \{ \cf3 arg\cf0  out=0;\
	\cf3 var\cf0  env, gate, density;\
	\cf3 Out\cf0 .ar(out, \
		env = \cf3 Env\cf0 .adsr(0.05, 0.1, 0.5, 0.5, 1, -4);\
		density = \cf3 MouseX\cf0 .kr(0.1,20,\cf4 'exponential'\cf0 );\
		\cf2 // 
\f2\b\fs24 Dust.ar(density, mul, add)\cf0 \
		
\f0\b0\fs36 gate = \cf3 Dust\cf0 .kr(density);\
		\cf3 WhiteNoise\cf0 .ar(\cf3 EnvGen\cf0 .kr(env,gate,\
		 		levelScale: \cf3 MouseY\cf0 .kr(0,1),	\
