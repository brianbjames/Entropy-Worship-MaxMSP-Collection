( \cf2 //	Ring Modulation, check online for diagram\cf0 \
\cf3 SynthDef\cf0 (\cf4 "ringMod"\cf0 ,\{ \cf3 arg\cf0  carFreq=400, modFreq=10.0, modIndex=0.5, amp=0.2;\cf5 //amp of carrier\cf0 \
	\cf3 var\cf0  rm; \
	rm = \cf3 SinOsc\cf0 .ar(carFreq,0,		\cf2 // carrier Sinewave, freq and phase, rm = ring modulation\cf0 \
		\cf3 SinOsc\cf0 .ar(modFreq,		\cf2 // amplitude is set by 2nd Sinewave\cf0 \
					0,					\cf2 // frequency phase\cf0 \
					modIndex)); 	\cf2 // amplitude sets index of modulation\cf0 \
	\cf3 Out\cf0 .ar(0,rm*amp)\
\}).store;\
\
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\carFreq\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\modFreq\cf0 ->\cf3 ControlSpec\cf0 (1.0,4000,\cf6 \\exp\cf0 ),\
	\cf6 \\modIndex\cf0 ->\cf3 ControlSpec\cf0 (0,1,\cf6 \\lin\cf0 )\
]);\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\ringMod\cf0 ));\
\
(	\cf2 //	Amplitude Modulation\cf0 \
\cf2 // in amplitude modulation the modulator output swings from 0 -> 1.0\cf0 \
\cf3 SynthDef\cf0 (\cf4 "ampMod"\cf0 ,\{ \cf3 arg\cf0  carFreq=400, modFreq=10.0, modIndex=0.5, amp=0.2;\
	\cf3 var\cf0  am;\
	am = \cf3 SinOsc\cf0 .ar(carFreq,0,\
		\cf3 SinOsc\cf0 .ar(modFreq,0,\
			modIndex*0.5,	\cf2 // amplitude of modulator = index/2, limiting range to 1\cf0 \
			0.5)); 	\cf2 // this is the 'add' argument, to shift range from -0.5 - +0.5 to 0 - 1.0, getting the hang of using the add arg is the trick\cf0 \
	\cf3 Out\cf0 .ar(0,am*amp)\
\}).store;\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\ampMod\cf0 ));\
(	\
\cf2 //	Simple FM \cf0 \
\cf3 SynthDef\cf0 (\cf4 "simpleFM"\cf0 ,\{ \cf3 arg\cf0  carFreq=400, modFreq=200, 				freqDev=100, amp=0.2;\
	\cf3 var\cf0  fm;\
	fm = \cf3 SinOsc\cf0 .ar(\
		\cf3 SinOsc\cf0 .ar(modFreq,	 \cf2 // carrier frequency controlled directly by modulator output, freq deviation is how much the modFreq mods the carFreq\cf0 \
			0,\
			freqDev,		\cf2 // the 'mul' argument of modulator will set frequency Deviation, because it sets the range of values being output by modulator\cf0 \
			carFreq), 	\cf2 //	the 'add' argument of the modulator adds center value of carFreq to the modulator output, the carFreq is providing the offset\cf0 \
		0,amp\
	);\
	\cf3 Out\cf0 .ar(0,fm)\
\}).store;\
\cf3 Spec\cf0 .specs.add(\cf6 \\freqDev\cf0 ->\cf3 ControlSpec\cf0 (0.001,4000.0,\cf6 \\exp\cf0 ));  \cf5 //0.001 because if 0 the computer will fail\cf0 \
)\
\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\simpleFM\cf0 ));\
\
(\
\cf2 //	Simple FM w/ GUI Index control\cf0 \
\cf3 SynthDef\cf0 (\cf4 "simpleFMIndex"\cf0 ,\{ \cf3 arg\cf0  carFreq=400, modFreq=200, 				index=1, amp=0.2;\
	\cf3 var\cf0  fm;\
	fm = \cf3 SinOsc\cf0 .ar( \
		\cf3 SinOsc\cf0 .ar(modFreq,0,\
		modFreq*index,	\cf2 // I = D/M, or I*M= D,\cf0 \
\cf2 // index = deviation/modFreq, or index*modFreq  = freqDeviation\cf0 \
		carFreq),\
		0,amp);\
	\cf3 Out\cf0 .ar(0,fm)\
\}).store;\
\cf3 Spec\cf0 .specs.add(\cf6 \\index\cf0 ->\cf3 ControlSpec\cf0 (0,16));\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\simpleFMIndex\cf0 ));\
\
(	\
\cf2 //	Simple FM w/ GUI Index and C:M ratio controls\cf0 \
\cf3 SynthDef\cf0 (\cf4 "simpleFM_CMratio"\cf0 ,\{  \cf3 arg\cf0  carFreq=400,cmRatio=1.0,\
	index=1,amp=0.2;\
	\cf3 var\cf0  fm, modFreq;\
	modFreq = carFreq/cmRatio;  \
				\cf2 // set modFreq by ratio of carFreq to modFreq\cf0 \
				\cf2 // fc / fm = cmRatio;  so, fm = fc/cmRatio\cf0 \
	fm = \cf3 SinOsc\cf0 .ar(\
		\cf3 SinOsc\cf0 .ar(modFreq,0,\
			modFreq*index,\
			carFreq\
		),\
		0,amp);\
	\cf3 Out\cf0 .ar(0,fm)\
\}).store;\
\cf3 Spec\cf0 .specs.add(\cf6 \\cmRatio\cf0 ->\cf3 ControlSpec\cf0 (0.1,20,\cf6 \\linear\cf0 ,0.1));\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\simpleFM_CMratio\cf0 ));\
\
( \cf2 // double Carrier, single modulator FM \cf0 \
\cf3 SynthDef\cf0 (\cf6 \\dblCarSglMod\cf0 ,\{ \cf3 arg\cf0  carFreq1=200, carAmp1=0.1, index1=1.0, 	carFreq2=300, carAmp2=0.1, index2=1.0, cmRatio=1.0, amp=0.2;\
	\cf3 var\cf0  fm, modFreq;\
	modFreq = carFreq1/cmRatio; \
	fm = \cf3 Mix\cf0 .new( \cf5 //if not Mix.new, stero voices would occur..due to it ebing multiplied by two\cf0 \
		\cf3 SinOsc\cf0 .ar(\
			\cf3 SinOsc\cf0 .ar(modFreq,0,\
				[index1,index2]*modFreq,\
				[carFreq1,carFreq2]\
			),0,\
			[carAmp1*0.5, carAmp2*0.5]	 \cf2 // avoid distortion since these mix\cf0 \
	));\
	\cf3 Out\cf0 .ar(0,fm*amp)\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\carFreq1\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\carFreq2\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\carAmp1\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\amp\cf0 ),\
	\cf6 \\carAmp2\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\amp\cf0 ),\
	\cf6 \\index1\cf0 ->\cf3 ControlSpec\cf0 (0,16),\
	\cf6 \\index2\cf0 ->\cf3 ControlSpec\cf0 (0,16)\
]);\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\dblCarSglMod\cf0 ));\
\
( \cf2 // double modulator, single carrier FM, sidebands of sidebands!\cf0 \
\cf3 SynthDef\cf0 (\cf6 \\dblModSglCar\cf0 ,\{ \cf3 arg\cf0  carFreq=200, carAmp=0.1, index1=1.0, 	index2=4.0,cmRatio1=0.5, cmRatio2=6.0,amp=0.2;\
	\cf3 var\cf0  fm, modFreq1, modFreq2, modulator;\
	modFreq1 = carFreq/cmRatio1; \
	modFreq2 = carFreq/cmRatio2; \
	fm = \cf3 SinOsc\cf0 .ar(\
		\cf3 Mix\cf0 .new([\
			\cf3 SinOsc\cf0 .ar(modFreq1,0,index1*modFreq1,carFreq),\
			\cf3 SinOsc\cf0 .ar(modFreq2,0,index2*modFreq2,carFreq)])\
	,0,carAmp);\
	\cf3 Out\cf0 .ar(0,fm*amp)\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\carFreq\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\carAmp\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\amp\cf0 ),\
	\cf6 \\index1\cf0 ->\cf3 ControlSpec\cf0 (0,16),\
	\cf6 \\index2\cf0 ->\cf3 ControlSpec\cf0 (0,16),\
	\cf6 \\cmRatio1\cf0 ->\cf3 ControlSpec\cf0 (0.1,20,\cf6 \\linear\cf0 ,0.1),\
	\cf6 \\cmRatio2\cf0 ->\cf3 ControlSpec\cf0 (0.1,20,\cf6 \\linear\cf0 ,0.1)\
]);\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf6 \\dblModSglCar\cf0 ));\
