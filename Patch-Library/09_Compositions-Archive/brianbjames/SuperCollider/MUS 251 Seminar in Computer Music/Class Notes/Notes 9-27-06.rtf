\cf2 // MORE ABOUT ENVELOPES:  Remember that the use of levelScale and timeScale arguments of EnvGen make an Env very flexible -- Env is essentially a specification of the \ul \ulc2 proportion\ulnone  of values and times that can be stretched. It's not possible to pass an Env as an argument, or as a Control, to a Synth.  Arguments of a Synth CAN however be used in an enclosed Env specification to change its shape as it runs, and you can even use Controls, as shown in last week's "Klank" code, to pass Arrays to change the levels and times Arrays of an Env inside a Synth. However, this can get messy if you want a lot of flexibility.  One simpler way of attaining a variety of  envelopes to control running Synths is to define multiple versions of that Synth, each containing a different envelope.  But if you still want more flexibility, you can define SynthDefs that do not output any sound, but that function as envelope generators by writing their control rate outputs to control busses.  The code below implements this method, and also forms an introduction to the class Bus, which provides a powerful facility for patching audio as well as control signals between running Synths.\cf0 \
\
( \cf2 // same as SynthDef above, but will use Bus.control inputs to for amp and indexCtls\cf0 \
\cf3 SynthDef\cf0 (\cf4 "dCarSModEnv"\cf0 ,\{ \cf3 arg\cf0  carFreq1=200, carFreq2=400, cmRatio=1.0, \
	ampCtl1=0.1, ampCtl2=0.1, indexCtl1=0.25, indexCtl2=0.25, amp=0.2;\
	\cf3 var\cf0  modFreq, fm;\
	modFreq = carFreq1/cmRatio;\
	\cf2 // use SendTrig to send values from a running Synth to SCLang where they can be viewed as they change-- an essential debugging tool!  See its help-file to see how to receive and print messages\cf0 \
	\cf3 SendTrig\cf0 .kr(\cf3 Impulse\cf0 .kr(10),1,indexCtl2); \cf2 // SendTrig (send trigger) args are trig, id, value: value is sent when a trigger occurs, and you assign the id (1) to distinguish between possible multiple triggers \cf0 \
	fm = \cf3 Mix\cf0 .new(\
		\cf3 SinOsc\cf0 .ar(\
			\cf3 SinOsc\cf0 .ar(modFreq,0,\
				[indexCtl1,indexCtl2]*modFreq,\
				[carFreq1,carFreq2]\
			),0,\
			[ampCtl1,ampCtl2]*0.5	 \cf2 // half the volume,  since these mix\cf0 \
	));\
	\cf3 Out\cf0 .ar(0,fm*amp)\
\}).store;\
\
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\carFreq1\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\carFreq2\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf6 \\freq\cf0 ),\
	\cf6 \\cmRatio\cf0 ->\cf3 ControlSpec\cf0 (0.1,20)\
]);\
\cf2 // make a number of envelopes that write to Bus.control outputs, no ar here...kr sends out on control busses, you dont hear it, it just affects the output\cf0 \
\cf3 SynthDef\cf0 (\cf6 \\ampEnv1\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum, \cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0],[0.2,0.8]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf6 \\ampEnv2\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0.1,0.5,0],[0.3,0.2,0.3,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf6 \\idxEnv1\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,10,2.0,0],[0.1,0.7,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf6 \\idxEnv2\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([10,0.5,4,1.0],[0.4,0.1,0.5]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
)\
\cf2 // play one FM Synth controlled by envGen Synths\cf0 \
( \cf3 var\cf0  ampEnvs,idxEnvs, dur, cBus;\
ampEnvs = [\cf6 \\ampEnv1\cf0 , \cf6 \\ampEnv2\cf0 ];\
idxEnvs = [\cf6 \\idxEnv1\cf0 , \cf6 \\idxEnv2\cf0 ];\
cBus = \cf3 Bus\cf0 .control(s,4);	\cf2 // this allocates 4 control Bus indices, like virtual patch chords and buffer on the server \cf0 \
\cf3 AutoGui\cf0 (x = \cf3 Synth\cf0 (\cf6 \\dCarSModEnv\cf0 ));\
x.map(\cf6 \\ampCtl1\cf0 ,cBus.index,\cf6 \\ampCtl2\cf0 ,cBus.index+1,\cf6 \\indexCtl1\cf0 ,cBus.index+2,\cf6 \\indexCtl2\cf0 ,cBus.index+3);\
\cf2 //	x.mapn(\\ampCtl1,cBus.index,4);  // this SHOULD also work, but there's a bug that I just reported, so it's not currently working\cf0 \
\cf3 Routine\cf0 (\{\
	loop(\{ \
		dur = rrand(0.1,3.0);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf6 \\ctlBusNum\cf0 ,cBus.index,\cf6 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf6 \\ctlBusNum\cf0 ,cBus.index+1,\cf6 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf6 \\ctlBusNum\cf0 ,cBus.index+2,\cf6 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf6 \\ctlBusNum\cf0 ,cBus.index+3,\cf6 \\dur\cf0 ,dur]);\
		(dur+0.2).wait     \cf5 //synths are being written to the busses\cf0 \
	\})\
\}).play;\
)\

