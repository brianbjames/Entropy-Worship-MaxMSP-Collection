\cf2 // The next example is a granular sampler, which will get rid of the click at the beginning and end of the sampler\cf0 \
\
(\
\cf3 SynthDef\cf0 (\cf4 "granSampler"\cf0 ,\{ \cf3 arg\cf0  sampbuf=0, rate=1, startPos=0, endPos=1.0, dir=1, loop=1.0;\
	\cf3 var\cf0  thisRate, thisDur, loopFrq, env;\
	thisRate = \cf3 BufRateScale\cf0 .kr(sampbuf)*rate;\
	thisDur = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(sampbuf));\
	loopFrq = (thisDur.reciprocal).min(100);\
	env = \cf3 Env\cf0 .new([0,1,1,0],[0.0125,1.0-0.025,0.0125]);  \
	\cf3 Out\cf0 .ar(0,\cf3 PlayBuf\cf0 .ar(1,			\cf2 // numChannels\cf0 \
		sampbuf,				\cf2 // which bufnum to play\cf0 \
		thisRate,   			\cf2 // rate\cf0 \
		\cf3 Impulse\cf0 .kr(loopFrq),		\cf2 // Impulse Ugen retriggers sample\cf0 \
		startPos*\cf3 BufFrames\cf0 .kr(sampbuf),  \cf2 // startPos\cf0 \
		loop)*\
		\cf2 // trigger an envelope on the sample "grain" in sync with loop\cf0 \
		\cf3 EnvGen\cf0 .ar(env,\cf3 Impulse\cf0 .kr(loopFrq), \cf2 // Impulse is 'gate' arg of EnvGen\cf0 \
					timeScale: thisDur.max(\cf3 BufRateScale\cf0 .kr(sampbuf)*0.01));\
	)\
\}).load(s);\
)\
x = \cf3 Synth\cf0 (\cf4 "granSampler"\cf0 ,[\cf5 \\startPos\cf0 ,0.2,\cf5 \\endPos\cf0 ,0.4]);\
x.set(\cf5 \\endPos\cf0 ,0.05);\
\
\cf2 // This next SynthDef plays just a single grain of sound before deAllocating itself using an EnvGen with doneAction: 2.  We will use the timeScale arg of the same EnvGen to adjust the length of the grain.\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "grain"\cf0 ,\{ \cf3 arg\cf0  bufnum=0, rate=1.0, startPos=0, size=1;\
	\cf3 Out\cf0 .ar(0,\
		\cf3 Pan2\cf0 .ar(\
			\cf3 PlayBuf\cf0 .ar(1,bufnum,\
				rate*\cf3 BufRateScale\cf0 .kr(bufnum),\
				1,			\cf2 // trigger\cf0 \
				startPos*\cf3 BufSamples\cf0 .kr(bufnum),\
				1), 		\cf2 // loop\cf0 \
			0,	\cf2 // pan position\cf0 \
			\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 ([0,0.2,0],[0.05,0.05],\cf5 \\sine\cf0 ), 1, \cf2 // a sinusoidal envelope\cf0 \
			\cf2 // timeScale will lengthen durations proportionally\cf0 \
			timeScale: size, doneAction: 2)\
		)\
	);\
\}).load(s); \
)\
x = \cf3 Synth\cf0 (\cf4 "grain"\cf0 ,[\cf4 "startPos"\cf0 ,0.5,\cf4 "size"\cf0 ,10]);\
