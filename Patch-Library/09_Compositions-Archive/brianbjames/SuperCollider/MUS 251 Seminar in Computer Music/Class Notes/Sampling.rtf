\cf2 // AudioIn channels start at 1 ! (left input)\cf0 \
\cf3 SynthDef\cf0 (\cf4 "audioIn"\cf0 ,\{ \cf3 arg\cf0  in=1; \
	\cf3 Out\cf0 .ar(0,\
		\cf3 Pan2\cf0 .ar(\cf3 AudioIn\cf0 .ar(in),	\cf2 // Pan2 balances the input between two adjacent outputs\cf0 \
			\cf3 SinOsc\cf0 .kr(0.2),		\cf2 // use a sinewave to control pan pos\cf0 \
