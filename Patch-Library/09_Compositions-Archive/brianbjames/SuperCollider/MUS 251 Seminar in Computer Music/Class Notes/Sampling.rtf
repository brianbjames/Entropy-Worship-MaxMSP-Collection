(	\cf2 // define a sampler\cf0 \
\cf3 SynthDef\cf0 (\cf4 "sampler"\cf0 ,\{ \cf3 arg\cf0  sampbuf=0, rate=1, startPos=0, 	loop=1.0;\
\cf2 //	PlayBuf.ar(numChannels,bufnum,rate,trigger,startPos,loop)\cf0 \
	\cf3 Out\cf0 .ar(0,\cf3 PlayBuf\cf0 .ar(1,			\cf2 // numChannels\cf0 \
		sampbuf,			\cf2 // which bufnum to play\cf0 \
		\cf3 BufRateScale\cf0 .kr(sampbuf)*rate,   \cf2 // gets sampRate for this Buffer\cf0 \
		1.0,		\cf2 // trigger arg, causes jump to startPos when changing from 0 (or less) to positive\cf0 \
		startPos*\cf3 BufFrames\cf0 .kr(sampbuf),  \cf2 // startPos, in sampleFrames of Buffer\cf0 \
		loop))			\cf2 // 1 means loop, 0 means no loop\cf0 \
\}).load(s);		\cf2 // load the SynthDef, but don't play it\cf0 \
)\
\
\cf2 // play the sampler, and change its rate using a Routine\cf0 \
( \cf3 var\cf0  buf, filename;\
filename = \cf4 "sounds/a11wlk01.wav"\cf0 ; 	\cf2 // give the directory path of your sample -- this points to the default soundfile within the "sounds" directory of the SC application -- put your own soundfile here, or direct it from the default SC folder to your own sounds directory, such as ../Desktop/mySound/\cf0 \
buf = \cf3 Buffer\cf0 .read(s,filename);	\cf2 // read the file into a new Buffer  on 's' Server\cf0 \
x = \cf3 Synth\cf0 (\cf4 "sampler"\cf0 ,[\cf4 "sampbuf"\cf0 , buf.bufnum]).play; \cf2 //play it -- the array argument of the"sampler" Synth sets its arguments in pairs of names and values, in this case the "sampbuf" arg, and its bufnum\cf0 \
\cf3 Routine\cf0 (\{\
	loop(\{ 								\cf2 // change it's rate\cf0 \
		x.set(\cf4 "rate"\cf0 ,rrand(-2.0,2.0).postln); \cf2 // choose a random rate between +-2.0\cf0 \
		rrand(2.0,0.2).wait		\cf2 // at random time intervals\cf0 \
	\})\
\}).play;\
)\
\
( 	\cf2 // this sampler allows you to set its loop endPos too, and introduces Classes that get important info about each different sample you use\cf0 \
\cf3 SynthDef\cf0 (\cf4 "loopSampler"\cf0 ,\{ \cf3 arg\cf0  sampbuf=0, rate=1, startPos=0, endPos=1.0,loop=1;\
	\cf3 var\cf0  thisRate, thisDur, loopFrq;\
		\cf2 // BufRateScale converts for differences in samplerate between different recorded samples and your playback rate\cf0 \
	thisRate = \cf3 BufRateScale\cf0 .kr(sampbuf)*rate;\
		\cf2 // BufDur gets the duration of the Buffer \cf0 \
		\cf2 // 'abs' method gets absolute value, to convert negative\cf0 \
		\cf2 //	results to positive durations\cf0 \
	thisDur = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(sampbuf));\
		\cf2 // frequency of looping is the reciprocal of the loop duration -- also guard against Infinite frequency using 'min' -- this returns the \cf2 \ul \ulc2 smaller\cf2 \ulnone  of the reciprocal or 100\cf0 \
	loopFrq = (thisDur.reciprocal).min(100);  \
	\cf3 Out\cf0 .ar(0,\
		\cf3 PlayBuf\cf0 .ar(1,			\cf2 // numChannels\cf0 \
		sampbuf,				\cf2 // which bufnum to play\cf0 \
		thisRate,   			\cf2 // rate\cf0 \
		\cf3 Impulse\cf0 .kr(loopFrq),		\cf2 // Impulse Ugen retriggers sample\cf0 \
		\cf2 // BufFrames gets number of sample frames of current sample\cf0 \
		startPos*\cf3 BufFrames\cf0 .kr(sampbuf),  \cf2 // startPos\cf0 \
		loop))\
\}).load(s);\
)\
\cf2 //  play the loopSampler\cf0 \
( \
	\cf3 var\cf0  buf, filename;\
	filename = \cf4 "sounds/a11wlk01.wav"\cf0 ;\
	buf = \cf3 Buffer\cf0 .read(s,filename);	\cf2 // read the file into a Buffer\cf0 \
	x = \cf3 Synth\cf0 (\cf4 "loopSampler"\cf0 ,\
		[\cf4 "sampbuf"\cf0 ,buf.bufnum,\cf4 "startPos"\cf0 ,0.3,\cf4 "endPos"\cf0 ,0.5]).play;\
)\
x.set(\cf4 "endPos"\cf0 ,0.34);\
x.set(\cf4 "rate"\cf0 ,-1.0);	\cf2 // note that negative rate, plays backwards\cf0 \
x.set(\cf4 "rate"\cf0 ,1.0);\
