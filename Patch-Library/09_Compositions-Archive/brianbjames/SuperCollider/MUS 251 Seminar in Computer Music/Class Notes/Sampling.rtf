\cf2 // the first time the sampler plays, it sometimes plays from the start of the sample -- why?  because the sample hasn't loaded yet, so there is no accurate count of the number of frames in the Buffer -- so, it is usually better to load your samples first, before starting any Synths that play them -- alternatively, you can use the 'action' argument of Buffer.read to start the Synth after reading is complete -- see the help-file for Buffer to see explanation, and here is an implemented version:\cf0 \
\
( \
	\cf3 var\cf0  filename;\
	filename = \cf4 "sounds/a11wlk01.wav"\cf0 ;\
	\cf3 Buffer\cf0 .read(s,filename,		\cf2 // read the file into a Buffer\cf0 \
		action: \{ \cf3 arg\cf0  buf;		\cf2 // the action is passed the new Buffer as an argument\cf0 \
			x = \cf3 Synth\cf0 (\cf4 "loopSampler"\cf0 ,		\cf2 // this is the completionMessage\cf0 \
			[\cf4 "sampbuf"\cf0 ,buf.bufnum,\cf4 "startPos"\cf0 ,0.15,\cf4 "endPos"\cf0 ,0.25]).play; \
		\}\
	);\
)\
\
 \cf2 // create another Buffer to record Audio input -- note that it's assigned to environmental variable 'b', so that we can continue to reference it in the next compilation\cf0 \
