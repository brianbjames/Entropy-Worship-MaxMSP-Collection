\cf2 // modulate the filter frequency with an LFO. This means you have to understand how the add works. \cf0 \
(\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 SynthDef\cf0 (\cf4 "modFilter"\cf0 ,\{ \cf3 arg\cf0  freq=120, ffreq=800, dcy=0.005, 	mfrq=0.2, dpth=0.1, vol=0.1;\
	\cf3 var\cf0  mod, flt;\
	mod = \cf3 SinOsc\cf0 .kr(mfrq,0,dpth*ffreq,ffreq); \cf5 //modulator!!!!\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 // this oscillator will control the frequency of the filter, which will center on ffreq, and oscillate at a low frequency up to + and - ffreq -- this is accomplished with the usage of the 'mul' and 'add' arguments, 'mul' makes the output of this oscillator swing between + and - the value of the filter's control frequency, and the 'add' argument shifts the modulating oscillator's center frequency from the 0 to ffreq\cf0 \
	flt = \cf3 Ringz\cf0 .ar(     \cf5 //flt = filter\cf0 \
		\cf3 Pulse\cf0 .ar(freq,0.1,0.25),	\cf2 // filter input\cf0 \
		mod,	\cf2 // filter frequency\cf0 \
		dcy,vol);    \cf5 //dcy = decay\cf0 \
	\cf3 Out\cf0 .ar(0,flt)\
\}).store;\
\
\cf2 // note:  we don't need to re-add any named args (like freq, ffreq and dcy) if we have already added them before and we want the same Control\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\mfrq\cf0 ->\cf3 Spec\cf0 .specs.at(\cf6 \\lofreq\cf0 ), 	\cf6 \\dpth\cf0 ->\cf3 ControlSpec\cf0 (0,1)\
]);\
)\
(\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf4 "modFilter"\cf0 ));\
)\
\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 //	strike a resonator, and it rings like a percussion instrument \cf0 \
(\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 SynthDef\cf0 (\cf4 "percFlt"\cf0 ,\{ \cf3 arg\cf0  rate=1, att=0.01, rls=0.1, ffreq=800, dcy=0.1,vol=0.5;\
	\cf3 var\cf0  striker;\
	\cf2 // Decay is  a simple low-pass filter, that provides an adjustable 60 dB decayTime in seconds for an Impulse Response-- Decay2, two of them, makes the output of one Decay into the input of another, and thus provides a smooth attackTime\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 // arg in = 0.0, attackTime = 0.01, decayTime = 1.0, mul = 1.0, add = 0.0;\cf0 \
	striker = \cf3 Decay2\cf0 .ar(\cf3 Impulse\cf0 .ar(rate),att,rls,0.25); \cf5 //Impulse is like hitting something\cf7 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf0 	\cf3 Out\cf0 .ar(0,\
		\cf3 Ringz\cf0 .ar(striker,ffreq,dcy,vol))\
\}).store;\
\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 Spec\cf0 .specs.addAll([\
	\cf6 \\rate\cf0 ->\cf3 Spec\cf0 .specs.at(\cf6 \\lofreq\cf0 ),\
	\cf6 \\rls\cf0 ->\cf3 ControlSpec\cf0 (0.001,1,\cf6 \\exponential\cf0 ),\
	\cf6 \\att\cf0 ->\cf3 ControlSpec\cf0 (0.001,0.05,\cf6 \\exponential\cf0 )\
]);\
)\
(\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf4 "percFlt"\cf0 ));\
)\
\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 // play the filter frequency using Pseq, a simple sequencer that outputs a 'Stream', which is a succession of numbers from the literal Array which is given as its first argument.  The second argument 'inf', says to repeat the Array forever, but you could specify an integer that makes the Pseq stop after that number of repeats    Pseq = pattern sequencer\cf0 \
(\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 var\cf0  seq;\
\cf3 AutoGui\cf0 (p = \cf3 Synth\cf0 (\cf4 "percFlt"\cf0 ));\
seq = \cf3 Pseq\cf0 (#[600, 400, 800, 1600, 3200], \cf3 inf\cf0 ).asStream; \cf5 //# = this Array cant change, AKA literal Array\cf0 \
\cf3 Routine\cf0 (\{\
	p.set(\cf6 \\rate\cf0 ,5);		\cf2 // set strike rate to same as seq\cf0 \
	loop(\{\
		p.set(\cf6 \\ffreq\cf0 ,seq.next.postln);\
		0.2.wait;\
	\})\
\}).play;\
)\
 \cf2 // Klank is a bank of resonators, like an Array of Ringz.  The first argument of Klank is its 'specifications', itself an Array of three Arrays that contain its frequencies, amplitudes, and decay.  See its help-file for more info.   !!!This example also uses a convenient method of Function:  'play' applied to a Function will automatically create a SynthDef and play it using Out.ar(0).!!!!  This is really great for quickly testing concepts for SynthDefs.   mul  = multiply\cf0 \
(\
\{ \cf3 Klank\cf0 .ar(`[      \cf5 //this syntax does need the ' mark\cf0 \
			\cf3 Array\cf0 .rand(12, 800.0, 4000.0), \cf2 //12 is how many of them it wil give us, these are frequencies\cf0 \
			\cf3 nil\cf0 ,  							\cf2 // amplitudes (default to 1.0)\cf0 \
			\cf3 Array\cf0 .rand(12, 0.1, 2)	\cf2 // ring times\cf0 \
		], \
		\cf3 Decay\cf0 .ar(\cf3 Impulse\cf0 .ar(4), \cf2 // filters' input\cf0 \
			0.03, 	\cf2 // decayTime		\cf0 \
			\cf3 ClipNoise\cf0 .ar(0.01) \cf2 // mul argument, creates a fuzzy strike!\cf0 \
		)\
	)\
\}.play;\
)\
\
\
\
\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
