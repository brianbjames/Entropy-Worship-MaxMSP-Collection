\f0\fs28 \cf2 // startup\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf0 s = \cf3 Server\cf0 .local;\
s.boot;\
(\
 \cf2 /*\
  Task: to randomly choose between three pitches in an Array:\
First, define a Synth that plays a sine wave, and load it to 's'\
 The first two arguments of a SynthDef are its name, and it's UgenGraphFunction\
*/\cf0 \
\cf3 SynthDef\cf0 (\cf4 "help-Osc"\cf0 ,\{ \cf3 arg\cf0  out=0, freq=200; 	\cf2 // these are its arguments\cf0 \
	\cf3 Out\cf0 .ar(out,\
		\cf3 SinOsc\cf0 .ar(freq, 0, 0.5)		\cf2 // freq=200, phase=0, amp = 0.5\cf0 \
	)\
\}).send(s);	\cf2 // 'send' the UGenGraphFunction to the server. There server must be running, and will know how to make a Synth from this SynthDef until it is restarted.  The method 'store' will write it to disk, and automatically load it every time you start the Server.  This is good for SynthDefs you never want to change.\cf0 \
)\
\
( \cf2 // Start the Synth playing, then run a 'Routine' that changes it's pitch\cf0 \
x = \cf3 Synth\cf0 (\cf4 "help-Osc"\cf0 ); \cf2 // start playing the Synth, and save a reference to it in the environment variable 'x'\cf0 \
p = [60, 63, 67];	\cf2 // an Array is defined by any objects enclosed by brackets [ ];\cf0 \
\cf2 // a Function is defined by a set of messages enclosed by curly-brackets \{ \}\cf0 \
\cf3 Routine\cf0 (\{	\cf2 // a Routine is a function that can pause execution of its function and resume where it left off\cf0 \
	loop(\{ 	\cf2 // do this function again and again, infinitely\cf0 \
		x.set(\cf4 "freq"\cf0 ,p.choose.midicps);	 \cf2 // set x's freq to a number chosen at random \cf0 \
			\cf2 //	by using  the 'choose' method applied to the Array p, converting it from a midikey number to cycles-per-sec using 'midicps' method\cf0 \
		1.0.wait	\cf2 // pause for 1 second\cf0 \
	\});\
\}).play;	\cf2 // the 'play' message starts executing the Routine\cf0 \
)\
\cf2 //	 cmd-period to stop !!\cf0 \
\
( \cf2 // VARIATION 1: choose freq from one of three pitch sets, which is also randomly chosen\cf0 \
\cf3 var\cf0  pitchSet1, pitchSet2, pitchSet3,freqArrays, source, ctr=0; \cf2 // these are variable definitions, which  are always defined at the top of code to be compiled\cf0 \
pitchSet1 = [60, 63, 67]; pitchSet2 = [65, 68, 72]; pitchSet3 = [67, 70, 73];\
freqArrays = [pitchSet1, pitchSet2, pitchSet3];\
source = pitchSet1;\
x = \cf3 Synth\cf0 (\cf4 "help-Osc"\cf0 );\
\cf3 Routine\cf0 (\{\
	loop(\{ \
		\cf2 // choose which array is the source\cf0 \
		\cf2 // 'if' requires two or three arguments; the first is a logical test, the second is a function to execute if the test is true, and the third (if it exists) is a function to evaluate if the test is false \cf0 \
		if( ctr ==  3,\{	\cf2 //    '==' means 'is equals to' and is a logical operator that  returns 'true' or 'false; if the test is true, then execute the function that follows the comma, otherwise do nothing, because there is no argument for the 'false' condition\cf0 \
			ctr = 0;	\cf2 // reset 'ctr' variable to 1\cf0 \
			source = freqArrays.choose.postln;  \cf2 // choose the next Array, and post (print) it to the Untitled window, then execute a line-feed (jump to new line)\cf0 \
		\});	\cf2 // end of true condition function\cf0 \
		x.set(\cf4 "freq"\cf0 ,source.choose.midicps);	\cf2 // set x to a freq chosen from current list\cf0 \
		ctr = ctr+1;	\cf2 // increment the ctr variable\cf0 \
		0.2.wait;\
	\});	\cf2 // end of loop\cf0 \
\}).play;\
)\
\
( \cf2 // now choose the arrays sequentially\cf0 \
\cf3 var\cf0  pitchSet1, pitchSet2, pitchSet3,freqArrays, source, ctr=0, arrayCtr=0;\
pitchSet1 = [60, 63, 67]; pitchSet2 = [65, 68, 72]; pitchSet3 = [67, 70, 73];\
freqArrays = [pitchSet1, pitchSet2, pitchSet3];\
source = pitchSet1;\
x = \cf3 Synth\cf0 (\cf4 "help-Osc"\cf0 );\
\cf3 Routine\cf0 (\{\
	loop(\{ \
		if( ctr == 0,\{\
			source = freqArrays[arrayCtr].postln; \cf2 //  pick the array from freqArrays 'at' arrayCtr\cf0 \
			arrayCtr = (arrayCtr+1).mod(3) \cf2 // 'mod' is short for 'modulo', and means "return remainder after divide"\cf0 \
		\});\
		x.set(\cf4 "freq"\cf0 ,source.choose.midicps);\
		ctr = (ctr+1).mod(3);\
		0.1.wait;\
	\});\
\}).play;\
)\
