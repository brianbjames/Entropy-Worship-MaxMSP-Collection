\cf3 //	ENVELOPES\cf2 \
\cf3 /*	Env.new(levels, times, curves, releaseNode, loopNode)\

\f1\b 	levels
\f0\b0  - an array of levels. The first level is the initial value of the envelope.\
	
\f1\b times
\f0\b0  - an array of durations of segments in seconds. There should be\
	one fewer duration than there are levels.\
	
\f1\b curve
\f0\b0  - this parameter determines the shape of the envelope segments.\
	
\f1\b releaseNode
\f0\b0  - an Integer or nil. If not nil, the envelope will sustain at the releaseNode until released.\
	
\f1\b loopNode
\f0\b0  - an Integer or nil. If not nil the sustain portion will loop from the releaseNode to the loop node.\
*/\cf2 \
\cf4 Env\cf2 .new([0.25,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf2 ,\cf4 nil\cf2 ,\cf4 nil\cf2 );\
\cf3 // levels of an 'exponential' Env must all be non-zero!!\cf2 \
\cf4 Env\cf2 .new([0.25,0.5,0.1],[1.0,0.5],\cf5 'exponential'\cf2 ,\cf4 nil\cf2 ,\cf4 nil\cf2 );\
\cf3 // sinusoidal curve\cf2 \
\cf4 Env\cf2 .new([0.25,0.5,0.0],[1.0,0.5],\cf5 'sine'\cf2 ,\cf4 nil\cf2 ,\cf4 nil\cf2 );\
\cf3 // the slope of curves can be specified by numbers\cf2 \
\cf4 Env\cf2 .new([0.25,0.5,0.0],[1.0,0.5],[4,-1],\cf4 nil\cf2 ,\cf4 nil\cf2 );\
\
\cf3 /* ENVELOPE GENERATOR: EnvGen\
EnvGen.ar(envelope, gate, levelScale, levelBias, timeScale, doneAction)\

\f1\b doneAction
\f0\b0  -\
	 the doneAction arg lets you cause the EnvGen to stop or end the \
	 Synth it is part of.  The most common doneActions are:\
	doneAction = 0   do nothing when the envelope has ended.\
 	doneAction = 1   pause the synth running, it is still resident.\
 	doneAction = 2   remove the synth and deallocate it.\
*/\cf2 \
\
\cf3 // make an envelope and use it in an EnvGen that multiplies the output of a SinOsc,  controlling its amplitude\cf2 \
(\
\cf4 SynthDef\cf2 (\cf5 \\envTest\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 var\cf2  env; \
	env = \cf4 Env\cf2 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf2 ,\cf4 nil\cf2 ,\cf4 nil\cf2 );\
	\cf4 Out\cf2 .ar(out,\
		\cf4 SinOsc\cf2 .ar(800,0,\
		\cf3 // note "keyword" style of supplying the doneAction arg --  args can be specified in any order, identified by 'name:'\cf2 \
			\cf4 EnvGen\cf2 .kr(env, doneAction: 2)))   \cf3 // env controls amplitude\cf2 \
\}).play;\
)\
\
(\cf3 // two envelopes, one for amplitude, one for frequency\cf2 \
\cf4 SynthDef\cf2 (\cf6 "twoEnvs"\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 var\cf2  ampEnv, freqEnv, sig;\
	ampEnv = \cf4 Env\cf2 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf2 );\
	\cf3 // try changing the curves of freqEnv\cf2 \
	freqEnv = \cf4 Env\cf2 .new([200,600,400],[1.0,0.5],[4,1]);\
	sig = \cf4 SinOsc\cf2 .ar(\cf4 EnvGen\cf2 .kr(freqEnv),\
						0,\cf4 EnvGen\cf2 .kr(ampEnv, doneAction: 2));\
	\cf4 Out\cf2 .ar(out,sig)\
\}).play\
)\
\
(\cf3 // two voices, each with both amplitude and frequency\cf2 \
\cf3 //		 envelopes - the envelopes are stored in arrays\cf2 \
\cf3 // this is a model for the instrument in the assignment\cf2 \
(\
\cf4 SynthDef\cf2 (\cf6 "duet"\cf2 ,\{ \cf4 arg\cf2  out;\
	\cf4 var\cf2  ampEnvelopes, freqEnvelopes;\
	ampEnvelopes = \
		[\
			\cf4 Env\cf2 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf2 ),\
			\cf4 Env\cf2 .new([0.0,0.5,0.0],[0.5,1.0],\cf5 'linear'\cf2 )\
		];\
	freqEnvelopes = \
		[\
			\cf4 Env\cf2 .new([200,600,400],[1.0,0.5],[4,1]),\
			\cf4 Env\cf2 .new([300,602,200],[1.0,0.5],[4,1])\
		];\
	\cf4 Out\cf2 .ar(out,\
		\cf4 SinOsc\cf2 .ar(\cf4 EnvGen\cf2 .kr(freqEnvelopes.at(0)),\
				0,\cf4 EnvGen\cf2 .kr(ampEnvelopes.at(0),doneAction: 2))\
		+				\cf3 // mixing the two oscillators\cf2 \
  		\cf4 SinOsc\cf2 .ar(\cf4 EnvGen\cf2 .kr(freqEnvelopes.at(1)),\
  				0,\cf4 EnvGen\cf2 .kr(ampEnvelopes.at(1),doneAction: 2)))\
 \}).play\
)\
\
( \cf3 // same, but stereo, instead of mixed  -- \cf2 \
\cf4 SynthDef\cf2 (\cf6 "duet"\cf2 ,\{ \cf4 arg\cf2  out;\
	\cf4 var\cf2  ampEnvelopes, freqEnvelopes;\
	ampEnvelopes = \
		[\
			\cf4 Env\cf2 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf2 ),\
			\cf4 Env\cf2 .new([0.0,0.5,0.0],[0.5,1.0],\cf5 'linear'\cf2 )\
		];\
	freqEnvelopes = \
		[\
			\cf4 Env\cf2 .new([200,600,400],[1.0,0.5],[4,1]),\
			\cf4 Env\cf2 .new([300,602,200],[1.0,0.5],[4,1])\
		];\
	\cf4 Out\cf2 .ar(out,\
		\cf3 // two oscillators in an Array\cf2 \
		[ \cf4 SinOsc\cf2 .ar(\cf4 EnvGen\cf2 .kr(freqEnvelopes.at(0)),0,\
			\cf4 EnvGen\cf2 .kr(ampEnvelopes.at(0), doneAction: 2)),\
		 \cf4 SinOsc\cf2 .ar(\cf4 EnvGen\cf2 .kr(freqEnvelopes.at(1)),0,\
			\cf4 EnvGen\cf2 .kr(ampEnvelopes.at(1), doneAction: 2))]\
  		)\
 \}).play\
)\
\
(\cf3 // other envelope creation methods \cf2 \
\cf4 SynthDef\cf2 (\cf6 "envTests"\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 var\cf2  env;\
	\cf3 //	*perc(attackTime, releaseTime, peakLevel, curve)\cf2 \
	\cf3 //	env = Env.perc(0.0,0.35,0.5,-1);\cf2 \
	\cf3 //	*triangle(duration, level)\cf2 \
	\cf3 //	env = Env.triangle(1.0,0.8);\cf2 \
	\cf3 //	*linen(attackTime, sustainTime, releaseTime, sustainLevel)\cf2 \
		env = \cf4 Env\cf2 .linen(0.1,2.5,0.5,0.8);\
	\cf4 Out\cf2 .ar(out,\
		\cf4 SinOsc\cf2 .ar(500,0,\cf4 EnvGen\cf2 .kr(env,doneAction: 2)))\
\}).play\
)\
\
\cf3 /* the Env methods 'adsr' and 'asr' create envelopes with\
 sustain segments,which stay at the sustain level \
	until explicitly released by the Synth that plays it:\
	*adsr(attackTime, decayTime, sustainLevel,  \
							releaseTime, peakLevel, curve)\
	*asr(attackTime, sustainLevel,  releaseTime, peakLevel, curve)\
	to control the release, the Synth must have an arg called 'gate'\
	which is open (value=1) when the Synth starts */\cf2 \
(	\
a = \cf4 SynthDef\cf2 (\cf6 "susEnvTests"\cf2 ,\{ \cf4 arg\cf2  out=0, gate=1;\
	\cf4 var\cf2  env;\
	env = \cf4 Env\cf2 .adsr(0.1, 0.2, 0.25, 0.8, 1, -4);\
	\cf4 Out\cf2 .ar(out,\
		\cf3 // the 'gate' arg controls the EnvGen release \cf2 \
		\cf4 SinOsc\cf2 .ar(500,0,\cf4 EnvGen\cf2 .kr(env,gate,doneAction: 2)))\
\}).play;\
)\
\cf3 // the method 'release' will set the 'gate' arg to 0, initiating the\cf2 \
\cf3 // release time segment\cf2 \
a.release;\
\
\cf3 //	EnvGen's 'gate' can be modulated to retrigger an Env\cf2 \
(	\cf3 // create a repeating note, \cf2 \
\cf3 //	using a pulse wave to gate and release EnvGen\cf2 \
a = \cf4 SynthDef\cf2 (\cf6 "repTest"\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 var\cf2  env, sig, speed, gate;\
	\cf3 // 
\f2\fs24 *
\f3\b adsr(attackTime, decayTime, sustainLevel,  releaseTime, peakLevel, curve)
\f0\b0\fs36 \cf2 \
	env = \cf4 Env\cf2 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
	\cf3 // MouseX-position controls gate speed\cf2 \
	gate = \cf4 LFPulse\cf2 .ar(\cf4 MouseX\cf2 .kr(0.2, 10, \cf5 'exponential'\cf2 ),0, \
	\cf3 // MouseY controls pulse-width of gate\cf2 \
		\cf4 MouseY\cf2 .kr(0.01,0.99));	\cf3 //  \cf2 \
	sig = \cf4 SinOsc\cf2 .ar(300, 0, \cf4 EnvGen\cf2 .kr(env,gate));\
	\cf4 Out\cf2 .ar(out,sig)\
\}).play;\
)\
a.free;\
\cf3 // now, add use of levelScale and timeScale args to change the \cf2 \
\cf3 // loudness and time of the same envelope as it plays\cf2 \
(\
\cf4 SynthDef\cf2 (\cf6 "repTest"\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 var\cf2  env, gate, sig, speed;\
	env = \cf4 Env\cf2 .adsr(0.05, 0.2, 0.25, 0.25, 1, -4);\
	\cf3 // MouseX-position controls gate speed\cf2 \
	speed = \cf4 MouseX\cf2 .kr(0.2, 20, \cf5 'exponential'\cf2 );\
	gate = \cf4 LFPulse\cf2 .kr(speed,0,0.5);\
	sig = \cf4 SinOsc\cf2 .ar(300, 0, \
		\cf4 EnvGen\cf2 .kr(env,gate, \
				levelScale: \cf4 MouseY\cf2 .kr(0,1),\
				timeScale: speed.reciprocal));\
	\cf4 Out\cf2 .ar(out,sig)\
\}).play;\
)\
