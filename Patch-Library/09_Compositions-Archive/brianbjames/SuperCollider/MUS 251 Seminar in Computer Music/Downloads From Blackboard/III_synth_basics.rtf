(	\cf3 // two sine oscillators are mixed\cf2 \
\cf4 SynthDef\cf2 (\cf5 \\addSynth\cf2 ,\{ \cf4 arg\cf2  out=0; \cf3 // note that backslash+string is the same as "string"\cf2 \
	\cf4 Out\cf2 .ar(out,\
		\cf4 SinOsc\cf2 .ar(440,0,0.5)		\cf3 // args are freq, phase, and mul (amp)\cf2 \
		+				\cf3 //	Adding is Mixing !!\cf2 \
		\cf4 SinOsc\cf2 .ar(660,0,0.5));\
\}).play;	 \cf3 // 'play' message sends SynthDef and starts a Synth in a single step\cf2 \
)\
\
\cf3 /* STEREO VERSION:  When an 
\f1\b Array
\f0\b0  is given as an input to a unit generator it causes an array of multiple copies of that unit generator to be made, each with a different value from the input array. This is called multichannel expansion.  Below, we get one SinOsc with freq=440 on the left (audio Bus = 0) and another SinOsc with freq=660 on the right (audio Bus = 1) */\cf2 \
(\
\cf4 SynthDef\cf2 (\cf5 \\stereoSines\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 Out\cf2 .ar(0,\cf4 SinOsc\cf2 .ar([440,660],0,0.5))\}).play;\
)\
\
\cf3 // Mix.fill(n,function) creates an array of n functions, then adds them -- try executing this one several times before stopping the sound with cmd-period\cf2 \
(\
\cf4 SynthDef\cf2 (\cf5 \\sin4Mix\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 Out\cf2 .ar(out,\
		\cf4 Mix\cf2 .fill(4,\{ \cf4 SinOsc\cf2 .ar(rrand(440,660),0,0.1) \})\
	)\
\}).play;\
)\
\
\cf3 // using Line and XLine to control the 'freq' arg of oscillators\cf2 \
\cf3 // Line's args are:  start, end, dur\cf2 \
(\
\cf4 SynthDef\cf2 (\cf5 \\lineTest\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 Out\cf2 .ar(0,\cf4 SinOsc\cf2 .ar(\cf4 Line\cf2 .kr(100,8000,4),0,0.1))\
\}).play;\
)\
\
\cf3 // compare XLine, exponential control of frequency sounds linear\cf2 \
(\
\cf4 SynthDef\cf2 (\cf5 \\xLineTest\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 Out\cf2 .ar(0,\cf4 SinOsc\cf2 .ar(\cf4 XLine\cf2 .kr(100,8000,4),0,0.1))\
\}).play;\
)\
\
\cf3 // other oscillators in SC3\cf2 \
\cf3 // Osc is a wavetable oscillator\cf2 \
(\
\cf4 Server\cf2 .default = \cf4 Server\cf2 .internal;	\cf3 // use the internal Server, so we can view the waveform\cf2 \
s = \cf4 Server\cf2 .default;\
s.waitForBoot(\{	\cf3 // this method boots the Server, and waits until it is ready to execute the Function\cf2 \
	b = \cf4 Buffer\cf2 .alloc(s, 512, 1);	\cf3 // creates a Buffer of 512 samples and 1 channel on s\cf2 \
	b.bufnum;				\cf3 // the 'bufnum' method returns the Buffer's index\cf2 \
\});\
)\
\cf3 /*	sine1 ( arg amplitudes,normalize=false,asWavetable=false,clearFirst=false); the sine1 method of Buffer creates a waveform that is the sum of a series of sinewave harmonics with amplitudes given by an Array of values passed to the arg "amplitudes"\
*/\cf2 \
b.sine1((1.0/[1,2,3,4,5,6]).postln);  \cf3 /* 1.0 is divided by each member of the Array, creating a 			new Array - try other math functions, but remember that 1.0 is the maximum\
*/\cf2 \
\
\cf3 // 	create a SynthDef called "help-Osc",  with arguments 'out' (an Audio Bus.index), and 'bufnum', a Buffer.index.\cf2 \
(\
\cf4 SynthDef\cf2 (\cf6 "help-Osc"\cf2 ,\{ \cf4 arg\cf2  out=0, bufnum=0, freq=200, amp=0.1;\
	\cf4 Out\cf2 .ar(out,\
	\cf3 //   Osc.ar(table, freq, phase, mul, add) -- an oscillator in which you provide the wavetable\cf2 \
		\cf4 Osc\cf2 .ar(bufnum, freq, 0, amp)	\cf3 // freq=200, phase=0, amp = 0.1\cf2 \
	)\
\}).load(s);		\cf3 // load the SynthDef to the 's' Server, which makes it ready to play.\cf2 \
)\
\cf3 //	now start the Synth by it's name, using arguments in the Array that follows the name and store the Synth instance in the environment variable 'x'\cf2 \
x = \cf4 Synth\cf2 (\cf6 "help-Osc"\cf2 ,[\cf5 \\out\cf2 , 0, \cf5 \\bufnum\cf2 , b.bufnum]);\
s.scope(2);	\cf3 // view the first two ouput channels\cf2 \
\cf3 // send messages to change the output chan assignment and freq\cf2 \
x.set(\cf6 "out"\cf2 ,1,\cf6 "freq"\cf2 ,800);\
x.set(\cf6 "out"\cf2 ,0,\cf6 "freq"\cf2 ,600);\
x.set(\cf6 "out"\cf2 ,1,\cf6 "freq"\cf2 ,400);\
\cf3 //	the 'free' message stops the Synth from playing, and erases it's object from the Server\cf2 \
x.free;\
\
\cf3 // Use the Ugens MouseX and MouseY to have parameters of a synth track the mouse position.  The arguments for these Ugens set low and high bounds corresponding to extreme edges of the screen.  This also introduces other SC Oscillators:  Saw, SyncSaw, Pulse, Blip\cf2 \
(\
\cf4 SynthDef\cf2 (\cf6 "test-Saw"\cf2 ,\{ \cf4 arg\cf2  freq=200, amp=0.1;\
	\cf4 Out\cf2 .ar(0, \
		\cf4 Saw\cf2 .ar([freq+\cf4 MouseX\cf2 .kr(-5,5), freq-\cf4 MouseX\cf2 .kr(-5,5)], \
			amp))\
\}).play;\
s.scope(2);	// 'scope' message plays and displays the Synth\
)\
\
(	\cf3 // SyncSaw demonstrates aliasing\cf2 \
\cf4 SynthDef\cf2 (\cf6 "test-SyncSaw"\cf2 ,\{ \cf4 arg\cf2  out=0;\
	\cf4 Out\cf2 .ar(out,\
		 \cf4 SyncSaw\cf2 .ar(100, \cf4 Line\cf2 .kr(100, 8000, 12), 0.2) \
	)\
\}).play;\
s.scope(2)\
)\
\
(	\cf3 // control pulse-width ratio (duty-cycle) of pulse waves, creating phase-cancellation effects\cf2 \
\cf4 SynthDef\cf2 (\cf6 "test-Pulse"\cf2 ,\{ \cf4 arg\cf2  freq=200, amp=0.1;\
	\cf4 Out\cf2 .ar(0, \
		\cf3 // Pulse.ar(freq, width, mul, add)\cf2 \
		\cf4 Pulse\cf2 .ar(freq, [\cf4 MouseX\cf2 .kr(0,1),\cf4 MouseY\cf2 .kr(0,1)], amp))\
\}).play;\
s.scope(2);	\
)\
\
( \cf3 // Blip.ar(kfreq, knumharmonics, mul, add) -- Band Limited ImPulse generator. All harmonics have equal amplitude.\cf2 \
\cf4 SynthDef\cf2 (\cf6 "test-Blip"\cf2 ,\{ \cf4 arg\cf2  freq=200, amp=0.1;\
	\cf4 Out\cf2 .ar(0, \
		\cf4 Blip\cf2 .ar(freq, [\cf4 MouseX\cf2 .kr(1,100),\cf4 MouseY\cf2 .kr(1,100)], amp))\
\}).play;\
s.scope(2);\
)\
