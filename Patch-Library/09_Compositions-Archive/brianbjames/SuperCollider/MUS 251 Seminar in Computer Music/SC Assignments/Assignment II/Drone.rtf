\cf3 //	ENVELOPES\cf0 \
\cf3 /*	Env.new(levels, times, curves, releaseNode, loopNode)\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural

\f1\b \cf3 	levels
\f0\b0  - an array of levels. The first level is the initial value of the envelope.\
	
\f1\b times
\f0\b0  - an array of durations of segments in seconds. There should be\
	one fewer duration than there are levels.\
	
\f1\b curve
\f0\b0  - this parameter determines the shape of the envelope segments.\
	
\f1\b releaseNode
\f0\b0  - an Integer or nil. If not nil, the envelope will sustain at the releaseNode until released.\
	
\f1\b loopNode
\f0\b0  - an Integer or nil. If not nil the sustain portion will loop from the releaseNode to the loop node.\
*/\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf0 ,\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;  \cf3 // plot in a GUI window\cf0 \
\cf3 // levels of an 'exponential' Env must all be non-zero!!\cf0 \
\cf2 Env\cf0 .new([0.25,0.5,0.1],[1.0,0.5],\cf5 'exponential'\cf0 ,\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;\
\cf3 // sinusoidal curve\cf0 \
\cf2 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],\cf5 'sine'\cf0 ,\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;\
\cf3 // the slope of curves can be specified by numbers\cf0 \
\cf2 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[4,1],\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;\
\cf2 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[4,-1],\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;\
\cf2 Env\cf0 .new([0.25,0.5,0.0],[1.0,0.5],[-4,1],\cf2 nil\cf0 ,\cf2 nil\cf0 ).plot;\
\
\cf3 /* ENVELOPE GENERATOR: EnvGen\
EnvGen.ar(envelope, gate, levelScale, levelBias, timeScale, doneAction)\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural

\f1\b \cf3 doneAction
\f0\b0  -\
	 the doneAction arg allows you to make the EnvGen end the \
	 Synth it is part of.  The most common doneActions are:\
	doneAction = 0   do nothing when the envelope has ended.\
 	doneAction = 1   pause the synth running, it is still resident.\
 	doneAction = 2   remove the synth and deallocate it.\
*/\cf0 \
\
\
\
(\cf3 // two envelopes, one for amplitude, one for frequency\cf0 \
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf2 SynthDef\cf0 (\cf4 "twoEnvs"\cf0 ,\{ \cf2 arg\cf0  out=0;\
	\cf2 var\cf0  ampEnv, freqEnv, sig;\
	ampEnv = \cf2 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf0 );\
	\cf3 // try changing the curves of freqEnv\cf0 \
	freqEnv = \cf2 Env\cf0 .new([200,600,400],[1.0,0.5],[4,1]);\
	sig = \cf2 SinOsc\cf0 .ar(\cf2 EnvGen\cf0 .kr(freqEnv),\
						0,\cf2 EnvGen\cf0 .kr(ampEnv, doneAction: 2));\
	\cf2 Out\cf0 .ar(out,sig)\
\}).play\
)\
\
\
(\
\cf2 SynthDef\cf0 (\cf4 "duet"\cf0 ,\{ \cf2 arg\cf0  out;\
	\cf2 var\cf0  ampEnvelopes, freqEnvelopes;\
	ampEnvelopes = \
		[\
			\cf2 Env\cf0 .new([0.0,0.5,0.0],[60.0,0.5],\cf5 'linear'\cf0 ),\
