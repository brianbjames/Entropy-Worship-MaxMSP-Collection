\f0\fs24 \cf0 (\
\cf2 Server\cf0 .default = \cf2 Server\cf0 .internal;	\cf3 // use the internal Server, so we can view the waveform\cf0 \
s = \cf2 Server\cf0 .default;\
s.waitForBoot(\{	\cf3 // this method boots the Server, and waits until it is ready to execute the Function\cf0 \
	b = \cf2 Buffer\cf0 .alloc(s, 512, 1);	\cf3 // creates a Buffer of 512 samples and 1 channel on s\cf0 \
	b.bufnum;			\cf3 // the 'bufnum' method returns the Buffer's index\cf0 \
\});\
)\
\cf3 /* sine1 ( arg amplitudes,normalize=false,asWavetable=false,clearFirst=false); \
the sine1 method of Buffer creates a waveform that is the sum of a series of sinewave harmonics with amplitudes given by an Array of values passed to the arg "amplitudes"\
*/\cf0 \
b.sine1((1.0/[1,2,3,4,5,6]).postln);  \
\cf3 /* 1.0 is divided by each member of the Array, creating a new Array - try other math functions, but remember that 1.0 is the maximum\
*/\cf0 \
\
\cf3 // 	create a SynthDef called "help-Osc",  with arguments 'out' (an Audio Bus.index), and 'bufnum', a Buffer.index.\cf0 \
(\
\cf2 SynthDef\cf0 (\cf4 "help-Osc"\cf0 ,\{ \cf2 arg\cf0  out=0, bufnum=0, freq=200, amp=0.1;\
	\cf2 Out\cf0 .ar(out,\
	\cf3 //   Osc.ar(table, freq, phase, mul, add) -- an oscillator in which you provide the wavetable\cf0 \
		\cf2 Osc\cf0 .ar(bufnum, freq, 0, amp)	\cf3 // freq=200, phase=0, amp = 0.1\cf0 \
	)\
\}).load(s);		\cf3 // load the SynthDef to the 's' Server, which makes it ready to play.\cf0 \
)\
\
