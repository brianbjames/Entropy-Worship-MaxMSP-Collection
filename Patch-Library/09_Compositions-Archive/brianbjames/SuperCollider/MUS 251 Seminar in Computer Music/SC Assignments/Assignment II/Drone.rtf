			\cf2 Env\cf0 .new([0.0,0.5,0.0],[1.0,0.5],\cf5 'linear'\cf0 ),\
			\cf2 Env\cf0 .new([0.0,0.5,0.0],[0.5,1.0],\cf5 'linear'\cf0 )\
		];\
	freqEnvelopes = \
		[\
			\cf2 Env\cf0 .new([5200,600,400],[1.0,0.25],[4,1]),\
			\cf2 Env\cf0 .new([300,602,200],[1.0,0.25],[4,1]), \
			\cf2 Env\cf0 .new([400,1200,800],[1.0,0.25],[4,1]),\
			\cf2 Env\cf0 .new([650,1202,400],[90.0,0.25],[4,1])\
		];\
	\cf2 Out\cf0 .ar(out,\
		\cf3 // two oscillators in an Array\cf0 \
		[ \cf2 SinOsc\cf0 .ar(\cf2 EnvGen\cf0 .kr(freqEnvelopes.at(0)),0,\
			\cf2 EnvGen\cf0 .kr(ampEnvelopes.at(0), doneAction: 2)),\
		 \cf2 SinOsc\cf0 .ar(\cf2 EnvGen\cf0 .kr(freqEnvelopes.at(1)),0,\
			\cf2 EnvGen\cf0 .kr(ampEnvelopes.at(1), doneAction: 2))]\
  		)\
 \}).play\
