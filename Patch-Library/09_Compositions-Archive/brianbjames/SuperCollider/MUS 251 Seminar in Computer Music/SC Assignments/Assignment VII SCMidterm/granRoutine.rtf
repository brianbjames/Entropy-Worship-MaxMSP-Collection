\f0\fs36 \cf2 SynthDef\cf3 (\cf4 "granSin"\cf3 ,\{ \cf2 arg\cf3  freq=400, dur=0.01,pan=0,amp=0.1;\
	\cf2 var\cf3  env, dir, saw, start;\
	env = \cf2 Env\cf3 .sine(dur);\
	\cf2 Out\cf3 .ar(0,\
		\cf2 EnvGen\cf3 .ar(env,doneAction: 2,timeScale: dur.max(0.00025))*\
