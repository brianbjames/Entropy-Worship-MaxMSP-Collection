	cloudBtn.action = \{ \cf2 arg\cf3  view;\
		\cf5 // create a Routine using cloudFunc\cf3 \
		\cf2 Routine\cf3 (cloudFunc).play(\cf2 AppClock\cf3 ); \cf5 // AppClock allows GUI interaction\cf3 \
	\};\
freqSlider = \cf2 SCRangeSlider\cf3 (w, \cf2 Rect\cf3 (10,145, 280,20)).lo_(0.4).hi_(0.6);\
