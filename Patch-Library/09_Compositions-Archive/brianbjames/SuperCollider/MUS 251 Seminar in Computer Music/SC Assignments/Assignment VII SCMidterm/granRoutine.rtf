( \
\cf2 var\cf3  w, cloudFunc,cloudBtn,freqSlider,freqSldText;\
\
\cf5 // this Function will be used, and reused, to create new granular clouds\cf3 \
cloudFunc = \{ \cf5 // each cloud generated will have its own unique variables\cf3 \
	\cf2 var\cf3  cloudDuration=10, startTime,freq,dur,amp,density,\
		lofreq,hifreq,lodur=0.05,hidur=0.5,loamp=0.1,hiamp=0.4;\
	startTime = \cf2 thisThread\cf3 .seconds;	\cf5 // this gets the seconds since SC startup\cf3 \
	density = rrand(0.1,8);	\
	\cf5 // use this kind of code to get values from an SCRangeSlider\cf3 \
	lofreq = [40,4000,\cf6 \\exp\cf3 ].asSpec.map(freqSlider.lo);\
	hifreq =  [40,4000,\cf6 \\exp\cf3 ].asSpec.map(freqSlider.hi); \
	\cf5 //  the first function after "while" is a test; if true, the next function executes -- once it fails, the Routine ends\cf3 \
	while(\{ \cf2 thisThread\cf3 .seconds  < (startTime+cloudDuration) \},\{ \
		freq=rrand(lofreq,hifreq);\
		dur = rrand(lodur,hidur);\
		amp = rrand(loamp,hiamp);\
		\cf2 Synth\cf3 (\cf4 "granSin"\cf3 ,[		\cf5 // replace with your own granular Synth\cf3 \
			\cf4 "freq"\cf3 ,freq,\
			\cf4 "dur"\cf3 , dur,\cf4 "amp"\cf3 ,amp]);\
		(dur/density).wait; \
	\});  \
\};\
\cf5 // the beginnings of a GUI to control all cloud parameters -- here, just controls to start the cloud, and to control its frequency range -- extend this to other parameters\cf3 \
w = \cf2 SCWindow\cf3 (\cf4 "cloudGen"\cf3 ); w.front;\
cloudBtn = \cf2 SCButton\cf3 (w, \cf2 Rect\cf3 (30,30, 80, 20));\
