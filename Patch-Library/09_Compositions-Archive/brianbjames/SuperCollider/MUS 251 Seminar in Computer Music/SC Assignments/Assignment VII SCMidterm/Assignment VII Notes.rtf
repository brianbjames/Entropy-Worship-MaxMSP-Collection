\cf3 SynthDef\cf0 (\cf4 "granSin"\cf0 ,\{ \cf3 arg\cf0  freq=400, dur=0.01,pan=0,amp=0.1;\
	\cf3 var\cf0  env, dir, saw, start;\
	env = \cf3 Env\cf0 .sine(dur);\
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(env,doneAction: 2,timeScale: dur.max(0.00025))*\
		\cf3 Pan2\cf0 .ar(\cf3 SinOsc\cf0 .ar(freq,0,amp),pan))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf4 "granNse"\cf0 ,\{ \cf3 arg\cf0  freq=400, dur=0.01,pan=0,amp=0.1;\
	\cf3 var\cf0  env, dir, saw, start;\
	env = \cf3 Env\cf0 .sine(dur);\
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(env,doneAction: 2,timeScale: dur.max(0.00025))*\
		\cf3 Pan2\cf0 .ar(\cf3 Ringz\cf0 .ar(\
				\cf3 WhiteNoise\cf0 .ar(amp*0.1),\
				freq,0.01),\
			pan))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf4 "granKlnk"\cf0 ,\{ \cf3 arg\cf0  freq=400, dur=0.01,pan=0,amp=0.1;\
	\cf3 var\cf0  env, dir, saw, start;\
	env = \cf3 Env\cf0 .sine(dur);\
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(env,doneAction: 2,timeScale: dur.max(0.00025))*\
		\cf3 Pan2\cf0 .ar(\cf3 Mix\cf0 (\
			\cf3 Ringz\cf0 .ar(\
				\cf3 Decay\cf0 .ar(\cf3 Impulse\cf0 .ar(dur.reciprocal),0.03,\
						\cf3 ClipNoise\cf0 .ar(amp*0.1)),\
				[freq,freq*1.5,freq*2.7,freq*5.9],dur)),\
			pan))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf4 "audioInRec"\cf0 ,\{ \cf3 arg\cf0  in=1,bufNum=0; \cf2 //writes audio input into a buffer\cf0 \
	\cf3 var\cf0  env,phasor;\
	phasor = \cf3 Phasor\cf0 .ar(0, \cf3 BufRateScale\cf0 .kr(bufNum), 0, \cf3 BufFrames\cf0 .kr(bufNum));\
	\cf3 BufWr\cf0 .ar(\cf3 AudioIn\cf0 .ar(in),bufNum,phasor,1);\
	0.0\
