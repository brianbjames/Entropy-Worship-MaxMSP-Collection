\
\cf3 SynthDef\cf0 (\cf4 "granPlayBuf"\cf0 ,\{ \cf3 arg\cf0  bufNum=0,loc=0,freq=400,dur=0.01,pan=0,amp=0.1;\
	\cf3 var\cf0  env,phasor,sig;\
