\cf2 /*  \
This is a variation on the granSampler, in which a stream of very short looping grains is produced whose start and end points automatically move at an adjustable rate of speed from a 'startPos' to 'endPos' of a Buffer.  You can use this instrument to change the playback rate of a sound without affecting its pitch, such as for slow motion effects, or to change pitch without changing duration.  The tradeoff is that you get envelope artifacts as part of the sound; try different envelopes to see what their effects are.\
*/\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "granSampScanner"\cf0 ,\{ \cf3 arg\cf0  bufnum=0, rate=1, startPos=0, endPos=1.0, windowSize=0.01, scanSpeed=1; \cf2 //windowSize is saying "what is the size of the grain in terms of time"\cf0 \
	\cf3 var\cf0  thisRate, thisDur, loopFrq, env, dir, saw, start;\
	\cf2 /* a sawtooth wave is used to specify an increment to the startPos, to scan the file - its speed is related to the duration of the part of the file to be 	scanned, times its scanSpeed */\cf0 \
	saw = \cf3 LFSaw\cf0 .kr(\
		((\cf3 BufDur\cf0 .kr(bufnum)*(endPos-startPos.abs)).reciprocal)*scanSpeed,\
		0,0.5,1);	\cf2 //  'mul' and 'add' args make output range = 0->1.0\cf0 \
	dir = (endPos-startPos).sign; \cf2 //dir is direction\cf0 \
	start = startPos+((endPos-startPos)*saw); \cf2 //this makes it point to the right thing\cf0 \
	thisRate = \cf3 BufRateScale\cf0 .kr(bufnum)*rate*dir;\
	thisDur = (windowSize*\cf3 BufDur\cf0 .kr(bufnum))/rate;\
	loopFrq = (thisDur.reciprocal).min(100);  \cf2 // guard against Infinite frequency\cf0 \
	env = \cf3 Env\cf0 .new([0,1,1,0],[0.1,0.8,0.1]);\
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(env,\cf3 Impulse\cf0 .kr(loopFrq),\
				timeScale: thisDur.max(\cf3 BufRateScale\cf0 .kr(bufnum)*0.01))*\
			\cf3 PlayBuf\cf0 .ar(1,bufnum,thisRate,   					\cf3 Impulse\cf0 .kr(loopFrq),\
				start*\cf3 BufFrames\cf0 .kr(bufnum),  \cf2 // startPos\cf0 \
			1))\
\}).store;\
)\
