(\
\cf2 // here's another way to read a file into a particular bufnum\cf0 \
s.sendMsg(\cf5 \\b_allocRead\cf0 , 10, \cf4 "sounds/
\f3 \cf0 metalcrash.aif
\f0 \cf4 "\cf0 ); \cf2 //another way to talk to the server, sendMsg means send to the server\cf0 \
)\
(\
\cf3 SynthDef\cf0 (\cf4 "TGrains-help"\cf0 ,\{ \cf3 arg\cf0  rate=1.0;\
	\cf3 var\cf0  b = 10, trate, dur;		\cf2 // now the bufnum can be referred to by number\cf0 \
	trate = \cf3 MouseY\cf0 .kr(2,120,1);		\cf2 // sets trigger rate of grains\cf0 \
	dur = 1.2 / trate;		\cf2 // sets duration of grains in relation to trate, so grains always overlap a little\cf0 \
	\cf3 Out\cf0 .ar(0,\
		\cf3 TGrains\cf0 .ar(2, \cf3 Impulse\cf0 .ar(trate), b, \
			rate,	\
			\cf3 MouseX\cf0 .kr(0,\cf3 BufDur\cf0 .kr(b)),  \cf2 // sets location of center of grain in Buffer\cf0 \
			dur, \
			\cf3 WhiteNoise\cf0 .kr(0.6), 	\cf2 // random panning\cf0 \
			0.1);	\cf2 // amplitude of grain\cf0 \
	)\
\}).store;\
)\
\cf3 Synth\cf0 (\cf4 "TGrains-help"\cf0 );\
\
(\cf2 //  this SynthDef plays just a single grain at a time, and it's up to you to generate individual Synths to make up streams or clouds of events using a Routine\cf0 \
\cf3 SynthDef\cf0 (\cf4 "granBuf"\cf0 ,\{ \cf3 arg\cf0  bufnum=0, rate=1.0, startPos=0, dur=0.1; \cf2 //dur is duration of grain\cf0 \
	\cf3 Out\cf0 .ar(0,\
		\cf3 Pan2\cf0 .ar(\
			\cf3 PlayBuf\cf0 .ar(1,bufnum,\
				rate*\cf3 BufRateScale\cf0 .kr(bufnum),\
				1,		\cf2 // trigger\cf0 \
				startPos*\cf3 BufSamples\cf0 .kr(bufnum),\
				1), 		\cf2 // loop\cf0 \
		1.0.rand2,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .sine(1,0.25),	\cf2 // sinusoidal envelope so that it doesnt click\cf0 \
				timeScale: dur, doneAction: 2))\
	);\
\}).store; \
)\
