\cf2 //Brown's example\cf0 \
(\
\cf3 var\cf0  gobutt,gotext,synthbutt,synthtext,\
durtext,durslide,freqtext,freqslide,panslide,pantext,\
ampslide,amptext,densslide,denstext,locslide,loctext,\
cfreq=400,frqRng=100,dur, cdur=0.1,location=0,inbuf=0,\
durRng=0.025,cpan=0,panRng=1,camp=0.1,ampRng=0.1,locRng=0.1,\
