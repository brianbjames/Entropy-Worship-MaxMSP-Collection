/*  Granular Sampling means that each loop has its own envelope.  Compare these two SynthDefs, familiar to you from the Sampling.rtf code examples */\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "loopSampler"\cf0 ,\{ \cf3 arg\cf0  bufnum=0, rate=1, startPos=0, endPos=1.0;\
	\cf3 var\cf0  thisRate, thisDur, loopFrq; \cf2 //buffer player\cf0 \
	thisRate = \cf3 BufRateScale\cf0 .kr(bufnum)*rate*((endPos-startPos).sign); \cf2 //takes difference btween endPos-startPos\cf0 \
	thisDur = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(bufnum))/rate; \
	loopFrq = (1.0/thisDur).min(100);  	\cf2 // min guards against Infinite frequency, reciprocal of previous line of code\cf0 \
	\cf3 Out\cf0 .ar(0,\cf3 PlayBuf\cf0 .ar(1, bufnum, thisRate,   		 \cf3 Impulse\cf0 .kr(loopFrq), \cf2 //trigger\cf0 \
		startPos*\cf3 BufFrames\cf0 .kr(bufnum),  \cf2 // startPos\cf0 \
	1))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf4 "granSampler"\cf0 ,\{ \cf3 arg\cf0  bufnum=0, rate=1, startPos=0, endPos=1.0;\
	\cf3 var\cf0  thisRate, thisDur, loopFrq, env;\
	thisRate = \cf3 BufRateScale\cf0 .kr(bufnum)*rate*((endPos-startPos).sign);\
	thisDur = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(bufnum))/rate;\
	loopFrq = (thisDur.reciprocal).min(100);  \cf2 //these three lines are same as above\cf0 	\cf2 // min guard against Infinite frequency\cf0 \
	env = \cf3 Env\cf0 .new([0,1,1,0],[0.05,1.0-0.1,0.05]); \cf2 //this code different that above, it can be used to control the env of the grains\cf0 \
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(env,\cf3 Impulse\cf0 .kr(loopFrq),	\cf2 // an EnvGen is 'gated' at the same\cf0 \
									\cf2 // rate as the sample is looped\cf0 \
				timeScale: thisDur.max(\cf3 BufRateScale\cf0 .kr(bufnum)*0.01))*\
			\cf3 PlayBuf\cf0 .ar(1,bufnum,thisRate,   					\cf3 Impulse\cf0 .kr(	loopFrq),\
				startPos*\cf3 BufFrames\cf0 .kr(bufnum),  \cf2 // startPos\cf0 \
			1))\
\}).store;\
)\
\cf2 /* now try the program below first with "loopSampler", move loop points and \
listen to the clicks; stop, and then use "granSampler", move loop points, and \
the clicks are enveloped away -- it's good to have the choice of clicks, or no\
clicks\
*/\cf0 \
(\
\cf3 var\cf0  myWind,rate=1.0,startPos=0,synth,buf, filename;\
myWind =  \cf3 SCWindow\cf0 .new(\cf4 "granSamp"\cf0 );\
\cf3 SCSlider\cf0 (myWind,\cf3 Rect\cf0 (120,20,20,200)).value_(0.5)\
	.action_(\{ \cf3 arg\cf0  slider; synth.set(\cf4 "rate"\cf0 , \
		\cf3 ControlSpec\cf0 .specs.at(\cf5 \\rate\cf0 ).map(slider.value)\
	); \
	\});\
\cf3 SCSlider\cf0 (myWind,\cf3 Rect\cf0 (150,20,20,200)).value_(0)\
	.action_(\{ \cf3 arg\cf0  slider; synth.set(\cf4 "startPos"\cf0 ,slider.value); \});\
\cf3 SCSlider\cf0 (myWind,\cf3 Rect\cf0 (180,20,20,200)).value_(1.0)\
	.action_(\{ \cf3 arg\cf0  slider; \
		synth.set(\cf4 "endPos"\cf0 ,slider.value);  \});\
