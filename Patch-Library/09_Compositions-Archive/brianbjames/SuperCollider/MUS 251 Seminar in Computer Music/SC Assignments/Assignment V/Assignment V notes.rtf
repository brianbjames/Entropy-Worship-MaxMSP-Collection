\cf3 SynthDef\cf0 (\cf4 "ringMod"\cf0 ,\{ \cf3 arg\cf0  carFreq=400, modFreq=10.0, modIndex=0.5, amp=0.2;\cf2 //amp of carrier\cf0 \
	\cf3 var\cf0  rm; \
