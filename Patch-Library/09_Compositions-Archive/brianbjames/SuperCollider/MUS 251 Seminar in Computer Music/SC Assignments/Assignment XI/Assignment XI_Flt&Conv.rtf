\cf2 SynthDef\cf0 (\cf4 "MagMul_convolve"\cf0 , \{ \cf2 arg\cf0  out=0,bufnumA=0, bufnumB = 1, \
							playbufnum1= 3, playbufnum2= 4;\
        \cf2 var\cf0  inA, inB, chain, chainB;\
   	\cf3 //	inA = WhiteNoise.ar(0.03); // try this too but un-(//)ing it \cf0 \
       inA = \cf2 PlayBuf\cf0 .ar(1,playbufnum1, 						\cf2 BufRateScale\cf0 .kr(playbufnum1), \
       				loop: 1)*0.5;\
        inB = \cf2 PlayBuf\cf0 .ar(1,playbufnum2, 					\cf2 BufRateScale\cf0 .kr(playbufnum2),\
        				loop: 1)*0.5;\
 \cf3 //  perform FFTs that change time-domain signals into frequency domain signals (frames of spectral amplitude, phase pairs)\cf0 \
        chain = \cf2 FFT\cf0 (bufnumA, inA);\
        chainB = \cf2 FFT\cf0 (bufnumB, inB);\
\pard\tx560\tx1120\tx1680\tx2240\tx2800\tx3360\tx3920\tx4480\tx5040\tx5600\tx6160\tx6720\ql\qnatural
\cf3 // multiplication of spectra == convolution of samples\cf0 \
        chain = \cf2 PV_MagMul\cf0 (chain, chainB);\
        \cf2 Out\cf0 .ar(out,\
                \cf2 IFFT\cf0 (chain) \cf3 // inverse FFT\cf0 \
        );\
\}).store;\
)\
