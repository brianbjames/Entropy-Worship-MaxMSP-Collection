\f0\fs30 \cf0 ( \cf2 //	HERE'S A SOLUTION FOR THE mmfmCascade Synth from last weeks assignment\cf0 \
\cf3 SynthDef\cf0 (\cf4 \\mmfmCascade\cf0 ,\{ \cf3 arg\cf0  carFreq=440, carAmp=0.2, cmRatio1=1, cmRatio2=1,index1=0.5, index2=0.1;\
	\cf3 var\cf0  mod1Freq, mod2Freq;\
	mod1Freq = cmRatio1*carFreq;  \
	mod2Freq = cmRatio2*mod1Freq;\
	\cf3 Out\cf0 .ar(0,\cf3 SinOsc\cf0 .ar(\
		\cf3 SinOsc\cf0 .ar(\
			\cf3 SinOsc\cf0 .ar(\
				mod2Freq,0,\
				mod2Freq*index2,		\cf2 // mul\cf0 \
				mod1Freq				\cf2 // add\cf0 \
			),\
			0, \
			mod1Freq*index1, 			\cf2 // mul\cf0 \
			carFreq),				\cf2 // add\cf0 \
		0, carAmp\
	))\
\}).store;\
\cf2 // add FM SPECS\cf0 \
\cf3 Spec\cf0 .specs.addAll([\
	\cf4 \\carFreq\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf4 \\freq\cf0 ),\
	\cf4 \\carAmp\cf0 ->\cf3 ControlSpec\cf0 .specs.at(\cf4 \\amp\cf0 ),\
	\cf4 \\index1\cf0 ->\cf3 ControlSpec\cf0 (0,16),\
	\cf4 \\index2\cf0 ->\cf3 ControlSpec\cf0 (0,16),\
	\cf4 \\cmRatio1\cf0 ->\cf3 ControlSpec\cf0 (0.1,20),\
	\cf4 \\cmRatio2\cf0 ->\cf3 ControlSpec\cf0 (0.1,20)\
]);\
)\cf3 \
AutoGui\cf0 (\cf3 Synth\cf0 (\cf5 "mmfmCascade"\cf0 ));\
\
