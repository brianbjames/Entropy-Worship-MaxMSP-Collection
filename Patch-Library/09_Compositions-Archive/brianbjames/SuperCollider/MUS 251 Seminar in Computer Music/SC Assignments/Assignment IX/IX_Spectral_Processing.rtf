( \cf2 // with spectral processing, you can have a "brickwall filter" \cf0 \
\cf3 SynthDef\cf0 (\cf4 "brickWall"\cf0 , \{ \cf3 arg\cf0  freq=200, wipe=0.0,nseAmp=0.2,plsAmp=0,bufnum=0;\
	\cf3 var\cf0  nse,pls, chain;\
	nse = \cf3 WhiteNoise\cf0 .ar(nseAmp);\
	pls = \cf3 Pulse\cf0 .ar(freq,0.01,plsAmp);\
	chain = \cf3 FFT\cf0 (bufnum, nse+pls);\
	\cf2 // wipe = 0 = no effect; wipe<0 = low pass; wipe>0 = high pass;\cf0 \
	chain = \cf3 PV_BrickWall\cf0 (chain, wipe); 	\cf3 Out\cf0 .ar(0,0.5 * \cf3 IFFT\cf0 (chain));\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf5 \\wipe\cf0 ->\cf3 ControlSpec\cf0 (-1,1)\
]);\
