(	\cf2 // PV_MagMul -- multiply magnitudes of two signals\cf0 \
\cf3 SynthDef\cf0 (\cf4 "ringFFT"\cf0 ,\{ \cf3 arg\cf0  freq=440, modDepth=0.1, amp=0.5;\
	\cf3 var\cf0  input1, input2, mousex, fft1, fft2,  ring;\
	input1 = \cf3 WhiteNoise\cf0 .ar(0.1);\
	input2 = \cf3 SinOsc\cf0 .ar(freq,0,modDepth);\
	fft1 = \cf3 FFT\cf0 (b.bufnum, input1);\
	fft2 = \cf3 FFT\cf0 (c.bufnum, input2);\
	ring = \cf3 PV_MagMul\cf0 (fft1, fft2);\
	\cf3 Out\cf0 .ar(0,\cf3 IFFT\cf0 (ring)*amp);\
\}).store;\
\cf3 Spec\cf0 .specs.add(\cf5 \\modDepth\cf0 ->\cf3 ControlSpec\cf0 (0,1));\
)\
