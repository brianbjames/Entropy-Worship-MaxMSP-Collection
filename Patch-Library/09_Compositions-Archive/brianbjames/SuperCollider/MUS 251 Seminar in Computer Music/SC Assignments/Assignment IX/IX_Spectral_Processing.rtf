(	\cf2 // brickWall filters an FM voice\cf0 \
\cf3 SynthDef\cf0 (\cf4 "osc-BrickWall"\cf0 , \{ \cf3 arg\cf0  cfreq=800, mfreq=100, bufnum=0,	wipe=0.1;		\cf2 // threshold in bins\cf0 \
	\cf3 var\cf0  in, chain;\
	in = \cf3 SinOsc\cf0 .ar(\
		\cf3 SinOsc\cf0 .ar(\
