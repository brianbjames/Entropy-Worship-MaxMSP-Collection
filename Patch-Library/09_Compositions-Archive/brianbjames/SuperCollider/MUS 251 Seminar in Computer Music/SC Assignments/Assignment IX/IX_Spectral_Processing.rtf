( \cf2 // binShift a sample\cf0 \
\cf3 SynthDef\cf0 (\cf4 "sampBinShift"\cf0 , \{ \cf3 arg\cf0  bufnum=0, sampBufnum=1, stretch=1, shift=0.0, rate=1,startPos=0,endPos=1,amp=0.5;\
	\cf3 var\cf0  in, chain, dir, dur;\
	dur = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(sampBufnum));\
	dir = (endPos-startPos).sign;\
	in = \cf3 PlayBuf\cf0 .ar(1,sampBufnum,\
			\cf3 BufRateScale\cf0 .kr(sampBufnum)*rate*dir,\
			\cf3 Impulse\cf0 .kr((1/dur).min(100)),\
			startPos*\cf3 BufFrames\cf0 .kr(sampBufnum), \
			endPos*\cf3 BufFrames\cf0 .kr(sampBufnum),1);\
	chain = \cf3 FFT\cf0 (bufnum, in);\
	chain = \cf3 PV_BinShift\cf0 (chain, stretch, shift); \
	\cf3 Out\cf0 .ar(0,amp * \cf3 IFFT\cf0 (chain));\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf5 \\startPos\cf0 ->\cf3 ControlSpec\cf0 (0,1),\
	\cf5 \\endPos\cf0 ->\cf3 ControlSpec\cf0 (0,1)\
]);\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf4 "sampBinShift"\cf0 ,[\cf5 \\bufnum\cf0 ,b.bufnum,\\sampBufnum,c.bufnum]));\
)\
