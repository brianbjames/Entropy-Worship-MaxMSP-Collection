(	\cf2 //	PV_MagClip .. limit magnitudes to a threshold, \cf0 \
\cf3 SynthDef\cf0 (\cf4 "magClip"\cf0 ,\{ \cf3 arg\cf0  freq=440, threshold=10, inAmp=0.5,\
	sawAmp=0.0,sinAmp=0.5,bufnum=0;\
	\cf3 var\cf0  in,saw,sin;\
	in = \cf3 AudioIn\cf0 .ar(1,inAmp);\
	saw = \cf3 Saw\cf0 .ar(freq,sawAmp);\
	sin = \cf3 SinOsc\cf0 .ar(freq,0,sinAmp);\
	\cf3 Out\cf0 .ar(0,\
		\cf3 IFFT\cf0 (\
			\cf3 PV_MagClip\cf0 (\
				\cf3 FFT\cf0 (bufnum, in+saw+sin),\
				threshold\
			);\
		)\
	)\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\cf5 \\inAmp\cf0 ->\cf5 \\amp\cf0 .asSpec]);\
)\
