\cf2 /*	PV_BinWipe .. spectral crossfade between two sounds \
(PV_BinWipe(inA, inB, wipe)\
as wipe goes from 0 to 1, begin copying in high bins from inB.\
as wipe goes from 0 to -1, begin copying in low bins from inB.\
*/\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "sampBinWipe"\cf0 , \{ \cf3 arg\cf0  bufnum1, bufnum2, sndBuf1, sndBuf2, wipe = 0.0, rate=1, startPos=0, endPos=1, amp=0.5;\
	\cf3 var\cf0  in1, in2, chain, chain1, chain2, dur1, dur2, dir, trig;\
	dur1 = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(sndBuf1));\
	dur2 = ((endPos-startPos).abs*\cf3 BufDur\cf0 .kr(sndBuf2));\
	dir = (endPos-startPos).sign;\
	in1 = \cf3 PlayBuf\cf0 .ar(1,sndBuf1,\
		\cf3 BufRateScale\cf0 .kr(sndBuf1)*rate*dir,\
		\cf3 Impulse\cf0 .kr((dur1.reciprocal).min(100)),\
		startPos*\cf3 BufFrames\cf0 .kr(sndBuf1), \
		endPos*\cf3 BufFrames\cf0 .kr(sndBuf1),\
	1);\
	chain1 = \cf3 FFT\cf0 (bufnum1, in1);\
	in2 = \cf3 PlayBuf\cf0 .ar(1,sndBuf2,\
		\cf3 BufRateScale\cf0 .kr(sndBuf2)*rate*dir,\
		\cf3 Impulse\cf0 .kr((dur2.reciprocal).min(100)),\
		startPos*\cf3 BufFrames\cf0 .kr(sndBuf2), \
		endPos*\cf3 BufFrames\cf0 .kr(sndBuf2),\
	1);	\
	chain2 = \cf3 FFT\cf0 (bufnum2, in2);\
	chain = \cf3 PV_BinWipe\cf0 (chain2, chain1, wipe); \
	\cf3 Out\cf0 .ar(0,amp * \cf3 IFFT\cf0 (chain))\
\}).store;\
)\
