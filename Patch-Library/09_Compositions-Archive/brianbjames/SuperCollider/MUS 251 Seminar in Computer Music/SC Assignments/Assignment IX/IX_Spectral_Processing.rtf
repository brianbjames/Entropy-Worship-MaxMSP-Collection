\cf2 /* 	BinShifting -- A very crude frequency shifter and scaler\
PV_BinShift args: buffer, stretch = 1.0, shift;  \
newbin = (shift + oldbin);\
stretch = scale bin position by a factor\
*/\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "binShift"\cf0 , \{ \cf3 arg\cf0  freq=100, stretch=1, shift=0.0,\
	sinAmp=0.5, plsAmp=0, inAmp=0, bufnum=0;\
	\cf3 var\cf0  in, chain;\
	in = \cf3 Mix\cf0 ([\cf3 SinOsc\cf0 .ar(freq,0,sinAmp),\
		\cf3 Pulse\cf0 .ar(freq,0.01,plsAmp),\
		\cf3 AudioIn\cf0 .ar(1,inAmp)]); \
	chain = \cf3 FFT\cf0 (bufnum, in);\
	chain = \cf3 PV_BinShift\cf0 (chain, stretch, shift); \
	\cf3 Out\cf0 .ar(0,0.5 * \cf3 IFFT\cf0 (chain));\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf5 \\stretch\cf0 ->\cf3 ControlSpec\cf0 (0.5,8,\cf5 \\exp\cf0 ,0.1),\
	\cf5 \\shift\cf0 ->\cf3 ControlSpec\cf0 (-128,128,\cf5 \\linear\cf0 ,1)\
]);\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf4 "binShift",[\\bufnum,b.bufnum]\cf0 ));\
