			0, mfreq,	\cf2 // modulation range\cf0 \
			cfreq)		\cf2 // center freq \cf0 \
	);\
	chain = \cf3 FFT\cf0 (bufnum, in);\
	chain = \cf3 PV_BrickWall\cf0 (chain, wipe); 	\cf3 Out\cf0 .ar(0,0.5 * \cf3 IFFT\cf0 (chain));\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\cf5 \\mfreq\cf0 ->\cf5 \\freq\cf0 .asSpec,\cf5 \\cfreq\cf0 ->\\freq.asSpec]);\
)\
