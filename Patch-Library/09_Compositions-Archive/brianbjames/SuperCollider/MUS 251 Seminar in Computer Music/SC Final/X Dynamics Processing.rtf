	\cf3 var\cf0  sig, env;\
	env = \cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1,1,0],[0.25,0.5,0.25]),\
				timeScale: envDur, doneAction: 2);\
	sig = \cf3 Shaper\cf0 .ar(bufnum, \
