\cf2 /*\
Compander	=	A general purpose dynamics processor, which can be configured as a compressor, expander, limiter, gate, ducker, etc.\
it's args are:\
Compander.ar(input, control, threshold, slopeBelow, 		slopeAbove, clampTime, relaxTime, mul, add)\
*/\cf0 \
\
(\
\cf2 // compressor\cf0 \
\cf3 SynthDef\cf0 (\cf5 \\compress\cf0 ,\{\
	\cf3 var\cf0  z;\
	\cf2 //	z = AudioIn.ar(1);\cf0 \
	z = \cf3 Decay2\cf0 .ar(\cf3 Impulse\cf0 .ar(4,0,0.5), \
					0.01, 0.4, \cf3 FSinOsc\cf0 .ar(200));\
	\cf3 Out\cf0 .ar(0,\cf3 Compander\cf0 .ar(z, z, \
		\cf3 MouseX\cf0 .kr(0.01, 1), 	\cf2 // threshold\cf0 \
		1, 						\cf2 // slope below is linear\cf0 \
		\cf3 MouseY\cf0 .kr(0.01,1), 	\cf2 // slope above\cf0 \
		0.001, 0.01);		\cf2 // clamp and relax times\cf0 \
	);\
\}).store;\
x = \cf3 Synth\cf0 (\cf5 \\compress\cf0 ); s.scope(1);\
)\
\
\cf2 // TRY USING THESE TO CONTROL AUDIO FEEDBACK\cf0 \
(\
\cf3 SynthDef\cf0 (\cf4 "compand"\cf0 ,\{ \cf3 arg\cf0  freq=2000,\
	thresh=0.1,below=1.0,above=1.0,\
	att=0.01,rls=0.01,amp=0.1;\
	\cf3 var\cf0  z;\
	z = \cf3 LPF\cf0 .ar(\cf3 AudioIn\cf0 .ar(1),freq);\
	\cf3 Out\cf0 .ar(0,\cf3 Compander\cf0 .ar(z,z,  \
		thresh, 	\cf2 // threshold\cf0 \
		below,above, \
		att,rls)*amp;		\cf2 // clamp and relax times\cf0 \
	);\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf5 \\thresh\cf0 ->\cf3 ControlSpec\cf0 (0.001,1.0,\cf5 \\lin\cf0 ,0.0,0.1),\
	\cf5 \\below\cf0 ->\cf3 ControlSpec\cf0 (0.01,20,\cf5 \\exp\cf0 ,0.0,1.0),\
	\cf5 \\above\cf0 ->\cf3 ControlSpec\cf0 (0.01,20,\cf5 \\exp\cf0 ,0.0,1.0),\
	\cf5 \\att\cf0 ->\cf3 ControlSpec\cf0 (0.001,1.0,\cf5 \\lin\cf0 ,0.0,0.01),\
	\cf5 \\rls\cf0 ->\cf3 ControlSpec\cf0 (0.001,1.0,\cf5 \\lin\cf0 ,0.0,0.01)])\
)\
\cf2 // run this on local Server because AutoGui doesn't work on Synths running on internal Server\cf0 \
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf5 \\compand\cf0 , target: \cf3 Server\cf0 .local));\
\
(\
\cf3 SynthDef\cf0 (\cf4 "compandFS"\cf0 ,\{ \cf3 arg\cf0  fsFreq=5, freq=2000,\
	thresh=0.1,below=1.0,above=1.0,\
	att=0.01,rls=0.01,amp=0.1;\
	\cf3 var\cf0  z;\
	z = \cf3 LPF\cf0 .ar(\cf3 AudioIn\cf0 .ar(1),freq);\
	\cf2 // Single-sideband amplitude modulation\cf0 \
	z = \cf3 FreqShift\cf0 .ar(z,fsFreq); \
	\cf3 Out\cf0 .ar(0,\cf3 Compander\cf0 .ar(z,z,  \
		thresh, 	\cf2 // threshold\cf0 \
		below,above, \
		att,rls)*amp;		\cf2 // clamp and relax times\cf0 \
	);\
\}).store;\
\cf3 Spec\cf0 .specs.addAll([\
	\cf5 \\fsFreq\cf0 ->\cf3 ControlSpec\cf0 (0.01,1000,\cf5 \\exp\cf0 ,0.0,5)])\
)\
\cf3 AutoGui\cf0 (\cf3 Synth\cf0 (\cf5 \\compandFS\cf0 , target: \cf3 Server\cf0 .local));\
\
\cf2 /* CompanderD passes the signal directly to the control input(dispensing with control arg), but adds a delay to the process input so that the lag in the gain clamping will not lag the attacks in the input sound.  In order to never overshoot, a limiter must have such characteristics.\
*/\cf0 \
(\
\cf2 // input limiter\cf0 \
\cf3 SynthDef\cf0 (\cf4 "limit"\cf0 ,\{\
	\cf3 var\cf0  z;\
	\cf2 //	z = AudioIn.ar(1);\cf0 \
	z = \cf3 Decay2\cf0 .ar(\cf3 Impulse\cf0 .ar(4,0,0.5), 0.01, 0.4, \cf3 FSinOsc\cf0 .ar(200));\
	\cf3 Out\cf0 .ar(0,\cf3 CompanderD\cf0 .ar(z, \
		\cf3 MouseX\cf0 .kr(0.01, 1), 	\cf2 // threshold\cf0 \
		1, 			\cf2 // slope below\cf0 \
		0.1, 		\cf2 // above threshold slope, = 10:1 compress\cf0 \
		0.01, 0.01);		\cf2 // clamp and relax times\cf0 \
	);\
\}).play;\
s.scope(1);\
)\
(\
\cf2 // input noise gate\cf0 \
\cf3 SynthDef\cf0 (\cf4 "noisegate"\cf0 ,\{\
	\cf3 var\cf0  z;\
	\cf2 //	z = AudioIn.ar(1);\cf0 \
	z = \cf3 Decay2\cf0 .ar(\cf3 Impulse\cf0 .ar(4,0,0.5), 0.01, 0.4, \cf3 FSinOsc\cf0 .ar(200));\
	\cf3 Out\cf0 .ar(0,\cf3 CompanderD\cf0 .ar(z,\
		\cf3 MouseX\cf0 .kr(0.01, 1.0), 	\cf2 // threshold\cf0 \
		20, 						\cf2 // slope below, input*20 makes output=1\cf0 \
		1, 					\cf2 // slope above = unity\cf0 \
		0.01, 0.01);		\cf2 // clamp and relax times\cf0 \
	);\
\}).play;\
)\
\
(\
\cf2 // input expander\cf0 \
\cf3 SynthDef\cf0 (\cf4 "expand"\cf0 ,\{\
	\cf3 var\cf0  z;\
	\cf2 //	z = AudioIn.ar(1);\cf0 \
	z = \cf3 Decay2\cf0 .ar(\cf3 Impulse\cf0 .ar(4,0,0.5), 0.01, 0.4, \cf3 FSinOsc\cf0 .ar(200));\
	\cf3 Out\cf0 .ar(0,\cf3 CompanderD\cf0 .ar(z,  \
		\cf3 MouseX\cf0 .kr(0.01, 0.5), 	\cf2 // threshold\cf0 \
		0.1, 			\cf2 // slope below, input of 0.1 makes output=1\cf0 \
		1, 			\cf2 // slope above = unity\cf0 \
		0.01, 0.01);		\cf2 // clamp and relax times\cf0 \
	);\
\}).play\
)\
