\cf2 // a simple Synth to sound a trigger\cf0 \
\cf3 (\
SynthDef\cf0 (\cf4 "ping"\cf0 ,\{ \cf3 arg\cf0  sfreq=800, efreq=700, dur=0.5;\
	\cf3 Out\cf0 .ar(0,\
		\cf3 EnvGen\cf0 .ar(\cf3 Env\cf0 .perc(0.01,0.5),doneAction: 2)*\
			\cf3 FSinOsc\cf0 .ar(\cf3 XLine\cf0 .kr(sfreq,efreq,dur),0,0.1)\
	);\
\}).store;\
)\
\cf2 //	Amplitude trigger\cf0 \
\cf2 (// Amplitude.kr(input,attackTime,releaseTime,mul,add)\cf0 \
\cf3 SynthDef\cf0 (\cf4 "ampTrig"\cf0 ,\{ \cf3 arg\cf0  speed=20;\
	\cf3 var\cf0  trig;\
	trig = \cf3 Impulse\cf0 .kr(speed);\
	\cf3 SendTrig\cf0 .kr(trig, \cf2 // send a trigger to SC-lang\cf0 \
			1,	\cf2 // a trigger ID, so multiple trigs can be\cf0 \
				\cf2 // distinguished\cf0 \
			\cf2 // next arg is a value to be polled and sent\cf0 \
			\cf2 // with the trigger message\cf0 \
			\cf3 Peak\cf0 .kr( \cf2 // tracks maximum value rec'vd\cf0 \
				\cf3 Amplitude\cf0 .kr( \cf2 //input of Peak is amp follower\cf0 \
					\cf3 AudioIn\cf0 .ar(1), 0.01, 0.01),\
			trig) \cf2 // resets output of Peak to current value\cf0 \
	);\
\}).store;\
)\
\cf2 /* an OSCresponder is a function in SC-lang that executes\
when an OSC message is received from a Server (or,\
from any NetAddr) -- its second argument is a symbol that matches to a particular response function, so there can be many different OSCresponders for different purposes. Look at the generic responder to SendTrig in its helpfile, which is useful in debugging Synths that compile but don't behave as expected:  just send values from the Synth as it runs to see if it is outputing what's expected.\
\
 Below, we use another OSCresponder to make a sound that tells us that an amplitude peak has been received\
*/\cf0 \
(\
\cf3 OSCresponder\cf0 (s.addr,\cf5 '/tr'\cf0 ,\{ \cf3 arg\cf0  time,responder,msg;\
	\cf3 var\cf0  thresh;\
\cf2 //	time.postln; responder.postln;\cf0 \
\cf2 //	msg.postln; "".postln;\cf0 \
\cf2 // if this trigger message has ID == 1\cf0 \
\cf2 // AND ('&&') if the value arg in the message is greater \cf0 \
\cf2 //			than some threshold, then, play a sound\cf0 \
	if( (msg.at(2) == 1) && (msg.at(3) > 0.1),						\{ msg.at(3).postln; \cf3 Synth\cf0 (\cf4 "ping"\cf0 ) \})\
\}).add;\
)\
\cf2 // start the trigger running\cf0 \
a = \cf3 Synth\cf0 (\cf4 "ampTrig"\cf0 );\
\
\cf2 /* let's make some other simple percussive generators, good as inputs for testing dynamics processors.    \
*/\cf0 \
\
play(\{ \cf3 FSinOsc\cf0 .ar(400,0,\cf3 LFPulse\cf0 .kr(5,0,0.2)) \});\
