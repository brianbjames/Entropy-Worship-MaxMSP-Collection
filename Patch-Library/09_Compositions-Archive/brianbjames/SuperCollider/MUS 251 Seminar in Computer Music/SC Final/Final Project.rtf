cloudFunc = \{ \
	\cf3 var\cf0  cloudDuration=10, startTime,freq,dur,amp,density,\
		lofreq,hifreq,lodur=0.05,hidur=5.0,loamp=0.001,hiamp=0.01;\
	startTime = \cf3 thisThread\cf0 .seconds;	\
	density = rrand(0.1,8);\
