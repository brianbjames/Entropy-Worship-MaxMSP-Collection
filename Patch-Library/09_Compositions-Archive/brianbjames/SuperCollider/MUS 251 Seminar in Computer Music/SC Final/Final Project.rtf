	hifreq =  [40,20000,\cf5 \\exp\cf0 ].asSpec.map(freqSlider.hi); \
	while(\{ \cf3 thisThread\cf0 .seconds  < (startTime+cloudDuration) \},\{ \
		freq=rrand(lofreq,hifreq);\
