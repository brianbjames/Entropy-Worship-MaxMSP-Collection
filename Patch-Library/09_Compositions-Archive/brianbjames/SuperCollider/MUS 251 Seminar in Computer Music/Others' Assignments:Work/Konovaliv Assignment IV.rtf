( 	\cf4 //Basic Loop Sampler\cf0 \
\cf2 SynthDef\cf0 (\cf3 "loopSampler"\cf0 ,\{ \cf2 arg\cf0  sampbuf=0, rate=1, startPos=0, endPos=1.0,loop=1; \cf4 //set arguments\cf0 \
	\
	\cf2 var\cf0  thisRate, thisDur, loopFrq, panPos=0.0;\cf4 //define variables\cf0 \
	\
	thisRate = \cf2 BufRateScale\cf0 .kr(sampbuf)*rate;\cf4 //Match Sampling Rate to Sample\cf0 \
	thisDur = ((endPos-startPos).abs*\cf2 BufDur\cf0 .kr(sampbuf)); \cf4 //Sets Buffer size (duration) positive\cf0 \
	loopFrq = (thisDur.reciprocal).min(100); \cf4 //loop frequency is reciprocal of sample rate \cf0 \
	\
	\cf2 Out\cf0 .ar(0,\
		\cf2 Pan2\cf0 .ar(\
			\cf2 PlayBuf\cf0 .ar(1,			\cf4 // numChannels\cf0 \
			sampbuf,				\cf4 // which bufnum to play\cf0 \
			thisRate,   			\cf4 // rate\cf0 \
			\cf2 Impulse\cf0 .kr(loopFrq),	\cf4 // Impulse Ugen retriggers sample\cf0 \
			\cf4 // BufFrames gets number of sample frames of current sample\cf0 \
			startPos*\cf2 BufFrames\cf0 .kr(sampbuf),  \cf4 // startPos\cf0 \
			loop)))\
\}).load(s);\
)\
