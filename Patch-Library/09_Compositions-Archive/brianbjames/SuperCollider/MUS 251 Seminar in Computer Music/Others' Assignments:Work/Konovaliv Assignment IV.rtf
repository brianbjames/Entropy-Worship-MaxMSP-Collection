\cf2 SynthDef\cf0 (\cf3 "grain"\cf0 ,\{ \cf2 arg\cf0  sampbuf=0, bufnum=0, rate=1.0, startPos=0, size=1, panPos=0;\
	\cf2 Out\cf0 .ar(0,\
