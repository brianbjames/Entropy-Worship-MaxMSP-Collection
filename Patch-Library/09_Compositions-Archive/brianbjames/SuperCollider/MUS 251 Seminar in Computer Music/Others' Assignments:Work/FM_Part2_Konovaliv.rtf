\cf2 // Playback - \cf0 \
( \cf3 var\cf0  ampEnvs,idxEnvs, freqEnvs, dur, dur2, cBus;\
ampEnvs = [\cf5 \\ampEnv1\cf0 , \cf5 \\ampEnv2\cf0 , \cf5 \\ampEnv3\cf0 , \cf5 \\ampEnv4\cf0 ];\
idxEnvs = [\cf5 \\idxEnv1\cf0 , \cf5 \\idxEnv2\cf0 , \cf5 \\idxEnv3\cf0 , \cf5 \\idxEnv4\cf0 ];\
freqEnvs = [\cf5 \\freqEnv3\cf0 , \cf5 \\freqEnv4\cf0 ];\
cBus = \cf3 Bus\cf0 .control(s,4);\
cBus2 = Bus.control(s, 6)	\cf2  \cf0 \
\
\cf2 //Synth1 User Control\
\cf3 Spec\cf0 .specs.add(\cf5 \\dur\cf0 ->\cf3 ControlSpec\cf0 (0.1,20,\cf5 \\linear\cf0 ,0.1));\
\cf3 AutoGui\cf0 (x = \cf3 Synth\cf0 (\cf5 \\dCarSModEnv\cf0 ));\
x.map(\cf5 \\ampCtl1\cf0 ,cBus.index,\cf5 \\ampCtl2\cf0 ,cBus.index+1,\cf5 \\indexCtl1\cf0 ,cBus.index+2,\cf5 \\indexCtl2\cf0 ,cBus.index+3);\
\
\cf2 //Synth2 Computer Control\cf0 \
y=\cf3 Synth\cf0 (\cf5 \\fm2\cf0 );\
y.map(\cf5 \\ampCtl3\cf0 , cBus.index+4, \cf5 \\ampCtl4\cf0 , cBus.index+5, \cf5 \\indexCtl3\cf0 , cBus.index+6, \cf5 \\indexCtl4\cf0 , cBus.index+7, \cf5 \\carFreq3\cf0 , cBus.index+8, \cf5 \\carFreq4\cf0 , cBus.index+9);\
\
\cf3 Routine\cf0 (\{\
	loop(\{ \
		dur = rrand(0.1,3.0);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+1,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+2,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+3,\cf5 \\dur\cf0 ,dur]);\
		(dur+0.2).wait\
	\})\
\}).play;\
\
\cf3 Routine\cf0 (\{\
	loop(\{ \
		dur2 = rrand(0.01,5.0);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+4,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (ampEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+5,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+6,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (idxEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+7,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (freqEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+8,\cf5 \\dur\cf0 ,dur]);\
		\cf3 Synth\cf0 (freqEnvs.choose,[\cf5 \\ctlBusNum\cf0 ,cBus.index+9,\cf5 \\dur\cf0 ,dur]);\
		y.set(\cf5 \\panPos2\cf0 , rrand(-1.0, 1.0));\
		(dur2+0.2).wait\
	\})\
\}).play;\
