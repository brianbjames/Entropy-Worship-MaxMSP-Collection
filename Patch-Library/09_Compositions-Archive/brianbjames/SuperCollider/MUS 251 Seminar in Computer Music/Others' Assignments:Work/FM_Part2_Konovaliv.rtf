\cf2 // Envelopes for Synth 1\cf0 \
\cf3 SynthDef\cf0 (\cf5 \\ampEnv1\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum, \cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0],[0.2,0.8]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf5 \\ampEnv2\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0.1,0.5,0],[0.3,0.2,0.3,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf5 \\idxEnv1\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,10,2.0,0],[0.1,0.7,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf5 \\idxEnv2\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([10,0.5,4,1.0],[0.4,0.1,0.5]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\
\
\
\cf2 // Envelopes for Synth 2\cf0 \
\
\cf2 //-------------------------Amp Envelopes - Synth 2\cf0 \
\cf3 SynthDef\cf0 (\cf5 \\ampEnv3\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum, \cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0],[0.2,0.8]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\
\cf3 SynthDef\cf0 (\cf5 \\ampEnv4\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,1.0,0.1,0.5,0],[0.3,0.2,0.3,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\
\cf2 //-------------------------index Envelopes - Synth 2\cf0 \
\cf3 SynthDef\cf0 (\cf5 \\idxEnv3\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([0,10,2.0,0],[0.1,0.7,0.2]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf5 \\idxEnv4\cf0 ,\{ \cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([10,0.5,4,1.0],[0.4,0.1,0.5]),\
		levelScale: amp, timeScale: dur, doneAction: 2))\
\}).store;\
\
\cf2 //-------------------------Frequency Envelopes - Synth 2\cf0 \
\cf3 SynthDef\cf0 (\cf5 \\freqEnv3\cf0 , \{\cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([200, 300, 100, 200], [0.5, 3, 0.25]),\
		levelScale:amp, timeScale: dur, doneAction:2))\
\}).store;\
\cf3 SynthDef\cf0 (\cf5 \\freqEnv4\cf0 , \{\cf3 arg\cf0  ctlBusNum=0, amp=1.0, dur=1.0;\
	\cf3 Out\cf0 .kr(ctlBusNum,\
		\cf3 EnvGen\cf0 .kr(\cf3 Env\cf0 .new([30, 60, 120, 240], [3.0, 0.25, 0.5]),\
		levelScale:amp, timeScale: dur, doneAction:2))\
\}).store;\
