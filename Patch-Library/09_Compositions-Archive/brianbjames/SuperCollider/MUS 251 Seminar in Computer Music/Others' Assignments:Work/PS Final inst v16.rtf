\f3\fs24 \cf3 ~lsBandPass = \{ \cf2 var\cf3  out=0, in=0;\
	\cf2 var\cf3  myWind, \
		loSlider, hiSlider, rqSlider, \
		rangeSlider, lagSlider, \
		doUpdate, memSliders, \
		inst;\
\cf4 // function to call when you update the rangeslider or the high and lo sliders\cf3 \
\cf4 // -- it sets them to the same values\cf3 \
doUpdate = \{	\cf2 arg\cf3  inLo, inHi;\
		\cf2 var\cf3  newLo, newHi;\
		if(inLo<inHi, \{newLo=inLo; newHi=inHi\}, \{newLo=inHi; newHi=inLo\});\
		rangeSlider.lo_(newLo);\
		rangeSlider.hi_(newHi);\
		loSlider.value = round(\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ).map(newLo), 1);\
		hiSlider.value = round(\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ).map(newHi));			\};\
\
myWind = \cf2 SCWindow\cf3 .new(\cf6 "BandPass"\cf3 , \cf2 Rect\cf3 (720, 
\fs72 300
\fs24 , 480, 300));\
myWind.view.decorator = \cf2 FlowLayout\cf3 (myWind.view.bounds);\
\cf4 // on close free the synth effect\cf3 \
myWind.onClose_(\{inst.free;\});\
rangeSlider = \cf2 SCRangeSlider\cf3 (myWind, \cf2 Rect\cf3 (0, 0, 470, 120))\
	.action_(\{\cf2 arg\cf3  me; doUpdate.value(me.lo.value, me.hi.value)\})\
	.knobColor_(\cf2 Color\cf3 .black);\
myWind.view.decorator.nextLine;\
\cf4 // this slider sets the synth low cutoff value\cf3 \
loSlider = \cf2 EZSlider\cf3 (myWind, 400 @ 24, \cf6 "Low Cutoff"\cf3 ,\
	\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ),\{\
			\cf2 |ez|\cf3  inst.set(\cf5 \\lo\cf3 , ez.value); \
			rangeSlider.lo_(\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ).unmap(ez.value));\
		\}, 20);\
myWind.view.decorator.nextLine;\
\cf4 // this slider sets the synth high cutoff value\cf3 \
hiSlider = \cf2 EZSlider\cf3 (myWind, 400 @ 24, \cf6 "High Cutoff"\cf3 , \
	\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ),\{\
			\cf2 |ez|\cf3  inst.set(\cf5 \\hi\cf3 , ez.value); \
			rangeSlider.hi_(\cf2 ControlSpec\cf3 .specs.at(\cf5 \\freq\cf3 ).unmap(ez.value));\
		\}, 20000);		\
myWind.view.decorator.nextLine;\
\cf4 // resonance for the filter\cf3 \
rqSlider = \cf2 EZSlider\cf3 (myWind, 200 @ 24, \cf6 "Rez"\cf3 , \
	\cf2 ControlSpec\cf3 (0.001, 2, \cf5 \\exp\cf3 , 0, 0.707),\
	\{\cf2 |ez|\cf3  inst.set(\cf5 \\rq\cf3 , ez.value); \}, 0.707, labelWidth: 40, numberWidth: 40);\
\cf4 // lag of the controls -- so it glides evenly\cf3 \
lagSlider = \cf2 EZSlider\cf3 (myWind, 200 @ 24, \cf6 "Lag"\cf3 , \
	\cf2 ControlSpec\cf3 (0, 20, \cf5 \\linear\cf3 , 0, 5),\
	\{\cf2 |ez|\cf3  inst.set(\cf5 \\lagTime\cf3 , ez.value); \}, 5, labelWidth: 40, numberWidth: 40).round_(0.01);\
myWind.view.decorator.nextLine;\
\
\cf4 // this is my tricky way of making an array of buttons and rangesliders.\cf3 \
