		\cf4 // Control bus for analysis data (on default server)\cf3 \
	stripBus = \cf2 Bus\cf3 .control(numChannels: 4);\
		\cf4 // analysis synth node.  writes to control bus. \cf3 \
	inst = \cf2 Synth\cf3 (\cf6 "lsAmpTrack"\cf3 , [\cf5 \\out\cf3 , stripBus.index, \cf5 \\in\cf3 , inBus, \cf5 \\gain\cf3 , 1], meterGroup);\
	\
		\cf4 // this channel strip's background\cf3 \
	stripView = \cf2 SCCompositeView\cf3 (meterWind, \cf2 Rect\cf3 (hx, yOffset, hw+mw+nw, chanHeight))\
			.background_(\cf2 Color\cf3 .new(0.0, 0.0, 0.0, 1.0));\
		\cf4 // Button that shows channel number.  If you click on it it pauses the synth node\cf3 \
	stripBtn = \cf2 SCButton\cf3 (stripView, \cf2 Rect\cf3 (5, 5+yOffset, 30, 30))\
		.font_(\cf2 Font\cf3 (\cf6 "Arial"\cf3 , 12))\
		.states_([ [(chanNumber+1).asString, \cf2 Color\cf3 .black, \cf2 Color\cf3 .gray(0.8)],\
					[\cf6 "||"\cf3 , \cf2 Color\cf3 .gray(0.8), \cf2 Color\cf3 .gray(0.2)] ])\
		.action_(\{ \cf2 |me|\cf3  inst.run(me.value==0);\});\
		\cf4 // Peak monitor.  I used a multislider because you can change the size and color\cf3 \
		\cf4 // of the slider thumb.  Someone cooler than me could make a multislider that \cf3 \
		\cf4 // handled all the channels instead of a slider for each channel.  Anyone?\cf3 \
	pSlider = \cf2 SCMultiSliderView\cf3 (stripView, \cf2 Rect\cf3 (mx, 5+yOffset, mw-5, 30))\
		.size_(1).canFocus_(\cf5 \\false\cf3 )\
		.valueThumbSize_(1)\
		.indexIsHorizontal_(\cf5 \\true\cf3 )\
		.isFilled_(\cf2 false\cf3 )\
		.thumbSize_(30).index_(0)\
		.strokeColor_(\cf2 Color\cf3 .yellow)\
		.fillColor_(\cf2 Color\cf3 .clear)\
		.background_(\cf2 Color\cf3 .clear);\
		\cf4 // Signal monitor.  This shows the current signal.  Change the color if you want\cf3 \
	sSlider = \cf2 SCMultiSliderView\cf3 (stripView, \cf2 Rect\cf3 (mx, 5+yOffset, mw-5, 30))\
		.size_(1).canFocus_(\cf5 \\false\cf3 )\
		.valueThumbSize_(1)\
		.indexIsHorizontal_(\cf5 \\true\cf3 )\
		.isFilled_(\cf2 true\cf3 )\
		.index_(0)\
		.fillColor_(\cf2 Color\cf3 .new(1.0, 0.0, 0.0, 0.75))\
		.strokeColor_(\cf2 Color\cf3 .red)\
		.background_(\cf2 Color\cf3 .clear)\
		.thumbSize_(30);\
		\cf4 // Peak Range.  This shows the max peak amount\cf3 \
	rSlider = \cf2 SCRangeSlider\cf3 (stripView, \cf2 Rect\cf3 (mx, 5+yOffset, mw-5, 30))\
		.knobColor_(\cf2 Color\cf3 .new(0.4, 0.2, 0.0, 0.7)).canFocus_(\cf5 \\false\cf3 );\
	\
	\cf2 SCStaticText\cf3 (stripView, \cf2 Rect\cf3 (nx, 3+yOffset, 25, 15))\
		.string_(\cf6 "peak"\cf3 ).font_(\cf2 Font\cf3 (\cf6 "Arial"\cf3 , 10)).stringColor_(\cf2 Color\cf3 .white);	\
		\cf4 // This box displays the peak value.  If you click it it resets.\cf3 \
	peakBox = \cf2 SCNumberBox\cf3 (stripView, \cf2 Rect\cf3 (nx+25, 3+yOffset, 40, 15))\
		.align_(1)\
		.mouseDownAction_(\{ inst.set(\cf5 \\t_reset\cf3 , 1);  \});\
	\
	\cf2 SCStaticText\cf3 (stripView, \cf2 Rect\cf3 (nx, 21+yOffset, 25, 15))\
		.string_(\cf6 "rms"\cf3 ).font_(\cf2 Font\cf3 (\cf6 "Arial"\cf3 , 10)).stringColor_(\cf2 Color\cf3 .white);	\
		\cf4 // This box displays the running RMS value.\cf3 \
	rmsBox = \cf2 SCNumberBox\cf3 (stripView, \cf2 Rect\cf3 (nx+25, 21+yOffset, 40, 15))\
		.align_(1)\
		.mouseDownAction_(\{ inst.set(\cf5 \\t_reset\cf3 , 1);  \});\
		\
		\cf4 // This is the client-side update process.  it loops at the speed specified by\cf3 \
		\cf4 // refreshRate (default 0.1) and polls the strip's control bus for the analysis info, then\cf3 \
		\cf4 // sets the gui values.  note that it uses .defer because it's all gui stuff\cf3 \
	proc = \cf2 Routine\cf3 (\{\
		\cf2 var\cf3  sig=0, peak=0, ceil=0, min=0;\
		loop(\{\
			stripBus.getn(4, \{\cf2 |vals|\cf3  sig=vals[0]; peak=vals[1]; min=vals[2]; ceil=vals[3];\});\
			\{\
			peakBox.value_(\cf5 \\db\cf3 .asSpec.map(ceil).round);\
			rmsBox.value_(\cf5 \\db\cf3 .asSpec.map(min).round(0.1));\
			pSlider.currentvalue_(\cf5 \\amp\cf3 .asSpec.unmap(peak));\
			sSlider.currentvalue_(\cf5 \\amp\cf3 .asSpec.unmap(sig));\
			rSlider.hi_(\cf5 \\amp\cf3 .asSpec.unmap(0));\
			rSlider.lo_(\cf5 \\amp\cf3 .asSpec.unmap(ceil));\
			\}.defer;\
			refreshRate.wait;\
		\});\
	\});\
\};\
