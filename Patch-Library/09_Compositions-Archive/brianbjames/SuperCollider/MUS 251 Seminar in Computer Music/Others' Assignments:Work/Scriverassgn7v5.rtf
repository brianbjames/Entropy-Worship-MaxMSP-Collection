\f2\fs26 \cf0 \
(\
\cf2 SynthDef\cf0 (\cf3 "SpeakandSpell"\cf0 ,\{\cf2 arg\cf0  rate = 1, pos=0.5, dur=1, bufnum=1;\
	\
	\cf2 var\cf0    pan;\
	\
	pan = \cf2 WhiteNoise\cf0 .kr(0.6);\
	\
	\cf2 Out\cf0 .ar(0,\
		\cf2 TGrains\cf0 .ar(2, Impulse.kr(1/dur), bufnum, rate, pos, dur, pan, 0.1)\
			*\cf2 EnvGen\cf0 .kr(\cf2 Env\cf0 .sine(1,0.25),	\
				timeScale: dur, doneAction: 2)*4;\
		);\
\}).store;\
)\
\
( \
\cf2 var\cf0  	w, \
	cloudFunc,cloudBtn,\
	freqSlider,freqSldText, \
	amp, ampSlider,ampSldText, \
	posSlider,posSldText, \
	rateSlider, rateSldText, \
	bufbutt, buftext, bufs, bufnum = 0;\
\
bufs=\cf2 Array\cf0 .new(4);	\cf4 // keep an array of buffers\cf0 \
	[	\
	\cf3 "sounds/kokoratikinokokorekedineke",\
	"sounds/Knowinvertor_mono.aif"\cf0 ,\
	\cf3 "sounds/PianoHarp_mono1.aif"\cf0 ,\
	\cf3 "sounds/dorothy waves.aif"\cf0 \
	]\
.do(\{\cf2 |filename|\cf0 \
	bufs = bufs.add(\cf2 Buffer\cf0 .read(s,filename))\});\
\
\cf4 // this Function will be used, and reused, to create new granular clouds\cf0 \
cloudFunc = \{ \cf4 // each cloud generated will have its own unique variables\cf0 \
			\cf2 var\cf0  cloudDuration=5, startTime,  density,\
				\
				freq,lofreq,hifreq,  \
				loamp=0.1,hiamp=0.4,\
				pos,lopos=0.1,hipos=0.5, \
				rate,lorate=1, hirate=1.2, 															dur,lodur=0.05,hidur=0.5;\
				\
				startTime = \cf2 thisThread\cf0 .seconds;	\cf4 // this gets the seconds since SC startup\cf0 \
				\
				density = rrand(0.1,8);	\
				\
				\
				\cf4 // use this kind of code to get values from an SCRangeSlider\cf0 \
				lofreq = [4,4000,\cf5 \\exp\cf0 ].asSpec.map(freqSlider.lo);\
				hifreq =  [4,4000,\cf5 \\exp\cf0 ].asSpec.map(freqSlider.hi); \
				\cf4 //copying freq info to amp info\cf0 \
				loamp = [0.01,1,\cf5 \\exp\cf0 ].asSpec.map(ampSlider.lo);\
				hiamp =  [0.01,1,\cf5 \\exp\cf0 ].asSpec.map(ampSlider.hi); \
				\cf4 //copying again to make duration info\cf0 \
				lopos = [0,10,\cf5 \\lin\cf0 ].asSpec.map(posSlider.lo);\
				hipos =  [0,10,\cf5 \\lin\cf0 ].asSpec.map(posSlider.hi); \
				\
				lorate = [-5, 5,\cf5 \\lin\cf0 ].asSpec.map(rateSlider.lo);\
				hirate =  [-5, 5,\cf5 \\lin\cf0 ].asSpec.map(rateSlider.hi); \
				\cf4 //  the first function after "while" is a test; if true, the next function executes -- once it fails, the Routine ends\cf0 \
					while(\{ \cf2 thisThread\cf0 .seconds  < (startTime+cloudDuration) \},\
						\{freq=rrand(lofreq,hifreq);\
							dur = rrand(lodur,hidur);\
							amp = rrand(loamp,hiamp);\
							rate = rrand(lorate, hirate);\
						\
							\cf2 Synth\cf0 (\cf3 "SpeakandSpell"\cf0 ,	\
								[								\
								\cf3 \\rate\cf0 ,rate,\
								\cf3 \\pos\cf0 , pos,\
								\cf3 \\bufnum\cf0 ,bufnum\
								]);\
									(dur/density).wait; \
						\});  \
\};\
\
