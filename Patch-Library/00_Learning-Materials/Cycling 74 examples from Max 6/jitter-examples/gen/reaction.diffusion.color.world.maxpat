, 							{
								"box" : 								{
									"code" : "derivative(img, size) {\r\n\thx = vec(size.x, 0);\r\n\thy = vec(0, size.y);\r\n\tdx = 0.5*(sample(img, norm+hx) - sample(img, norm-hx));\r\n\tdy = 0.5*(sample(img, norm+hy) - sample(img, norm-hy));\r\n\treturn dx, dy;\r\n}\r\n\r\nParam rnd(0.1, 0.3);\r\nParam weights(0.1, 0.5, 0.1, 0);\r\n\r\nwnorm = normalize(weights);\r\npixsize = 1/dim;\r\ndx, dy = derivative(in2, 4*pixsize);\r\noffset = norm + vec(dot(dx, wnorm), dot(dy, wnorm))*pixsize*8;\r\nrand = sample(in3, offset + rnd).xy;\r\n// reaction-diffusion\r\nres = sample(in1, offset) + (rand.x-0.5)*0.0025 - 0.002;\r\nout = res - 0.047*(\r\n\tsample(in2, offset + (rand-0.5)*pixsize) -\r\n\tsample(in1, offset + (rand-0.5)*pixsize)\r\n);",
									"fontname" : "Arial",
									"fontsize" : 12.0,
									"id" : "obj-3",
									"maxclass" : "codebox",
									"numinlets" : 3,
