								}

							}
, 							{
								"box" : 								{
									"maxclass" : "comment",
									"text" : "This abstraction generates and outputs improvised or fixed cycles of ints, floats and symbols. The principle consists in entering a list of values, which can be read in different manners : cyclically (up, down, forwards, backwards...) or randomly (permut, alea). The second aspect is when to trigger the different entries. As the abstraction is supposed to play sequences, we need to feed it up with time events. By default it understands a \"bang\" message, which must be sent to its input. Each of the bangs will be interprated as a further step in the triggering of the items in the list. The reason why the \"trigger\" menus has several options other than the simple input bang, is that the abstraction is designed to work together with the \"X.groove\" abstraction. The X.groove abstraction outputs improvised rhythmic sequences, together with different information such as when a pulse is played, if the pulse is played or if it is paused, if the rhythm interval was changed or not, etc. All these information is synchonized in time, and can be used by the X.list abstraction in order to output its content.",
									"linecount" : 9,
									"fontsize" : 11.595187,
									"patching_rect" : [ 22.0, 431.0, 660.0, 126.0 ],
									"numinlets" : 1,
									"id" : "obj-36",
									"numoutlets" : 0,
									"fontname" : "Arial"
								}

							}
