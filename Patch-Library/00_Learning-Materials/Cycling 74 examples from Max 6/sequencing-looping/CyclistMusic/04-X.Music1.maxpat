, 			{
				"box" : 				{
					"maxclass" : "comment",
					"text" : "This patch is a sketch of an evolutive control&audio instrument  based on rhythm generation, where all timing objects are synchronized to a master transport clock. A funny (depending on each one's taste) way of seeing how several processes can play together is to load the X.Groover MIDI patch for instance, and to select some presets there.\nYou can even try to also load the X.Midinote patch, for unpredictable results.",
					"linecount" : 6,
					"fontsize" : 13.914225,
					"frgb" : [ 0.533333, 0.533333, 0.74902, 1.0 ],
					"textcolor" : [ 0.533333, 0.533333, 0.74902, 1.0 ],
					"patching_rect" : [ 225.0, 599.0, 518.0, 102.0 ],
					"numinlets" : 1,
					"id" : "obj-55",
					"numoutlets" : 0,
					"fontname" : "Arial Bold Italic"
				}

