, 							{
								"box" : 								{
									"code" : "// sample&hold step function; returns value, phase and trigger\r\nstepfunc(freq, src) {\r\n\tHistory v;\r\n\tp = phasor(freq);\r\n\ttrig = delta(p) < 0;\r\n\tv = trig ? src : v;\r\n\treturn v, p, trig;\r\n}\r\n// interpolators with trigger:\r\nlinear(v, a, trig) {\r\n\tHistory x, y;\r\n\tx = trig ? y : x;\r\n\ty = trig ? v : y;\r\n\treturn x + a*(y-x);\r\n}\r\ncosine(v, a, trig) {\r\n\tHistory x, y;\r\n\tx = trig ? y : x;\r\n\ty = trig ? v : y;\r\n\ta2 = 0.5*(1-cos(a*pi));\r\n\treturn x + a2*(y-x);\r\n}\r\ncubic(v, a, trig) {\r\n\tHistory w, x, y, z;\r\n\tw = trig ? x : w;\r\n\tx = trig ? y : x;\r\n\ty = trig ? z : y;\r\n\tz = trig ? v : z;\r\n\ta2 = a*a;\n\tf0 = z - y - w + x;\n\tf1 = w - x - f0;\n\tf2 = y - w;\n\treturn f0*a*a2 + f1*a2 + f2*a + x;\r\n}\r\nspline(v, a, trig) {\r\n\tHistory w, x, y, z;\r\n\tw = trig ? x : w;\r\n\tx = trig ? y : x;\r\n\ty = trig ? z : y;\r\n\tz = trig ? v : z;\r\n\ta2 = a*a;\n\tf0 = -0.5*w + 1.5*x - 1.5*y + 0.5*z;\n\tf1 = w - 2.5*x + 2*y - 0.5*z;\n\tf2 = -0.5*w + 0.5*y;\n\treturn f0*a*a2 + f1*a2 + f2*a + x;\r\n}\r\nhermite(v, a, trig, bias, tension) {\r\n\tHistory w, x, y, z;\r\n\tw = trig ? x : w;\r\n\tx = trig ? y : x;\r\n\ty = trig ? z : y;\r\n\tz = trig ? v : z;\r\n\taa = a*a;\r\n\taaa = a*aa;\r\n\tbp, bm = 1+bias, 1-bias;\r\n\tmt = (1-tension)*0.5;\r\n\tm0  = ((x-w)*bp + (y-x)*bm) * mt;\n\tm1  = ((y-x)*bp + (z-y)*bm) * mt;\r\n\ta0 =  2*aaa - 3*aa + 1;\n   \ta1 =    aaa - 2*aa + a;\n   \ta2 =    aaa -   aa;\n   \ta3 = -2*aaa + 3*aa;\n   \treturn a0*x + a1*m0 + a2*m1 + a3*y;\r\n}\r\npulsefreq, src, bias, tension = in1, in2, in3, in4;\r\nr, a, trig = stepfunc(pulsefreq, src);\r\nout1 = r;\r\nout2 = linear(r, a, trig);\r\nout3 = cosine(r, a, trig);\r\nout4 = cubic(r, a, trig);\r\nout5 = spline(r, a, trig);\r\nout6 = hermite(r, a, trig, bias, tension);",
									"fontname" : "Arial",
									"fontsize" : 12.0,
									"id" : "obj-3",
									"maxclass" : "codebox",
									"numinlets" : 4,
									"numoutlets" : 6,
									"outlettype" : [ "", "", "", "", "", "" ],
									"patching_rect" : [ 11.0, 35.0, 649.0, 739.0 ]
								}

