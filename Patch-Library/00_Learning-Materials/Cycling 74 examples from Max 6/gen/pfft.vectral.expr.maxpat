								"box" : 								{
									"code" : "// This does a vectral~ style smoothing on the amplitudes of each FFT bin\r\n\r\n// create a Data object to hold the previous frame:\r\n// (amp in channel 0, phase in channel 1)\r\nData prev(fftsize, 2);\r\n// a smoothing parameter:\nParam smooth(0.99); //, max=0.99, min=0);\n\r\n// convert FFT input to amp, phase:\namp, phase = cartopol(in1, in2);\r\n// third input is the current bin number:\r\nbin = in3;\r\n\r\n// here's the smoothing algorithm\r\n// read from Data:\noldamp = peek(prev, bin, 0);\r\n// blend with current amplitude:\r\n// (insert fancier algorithm here for slide~, deltaclip~, rampsmooth~ etc. beheavior)\namp = mix(amp, oldamp, smooth);\r\n// feedback into Data:\r\npoke(prev, amp, bin, 0, 0);\r\n\r\n// also smoothing phase (doesn't necessarily make sense...)\r\n// probably should use phase deltas instead? add another Data channel for that... \noldphase = peek(prev, bin, 1);\n//phase = mix(phase, oldphase, smooth);\r\n//poke(prev, phase, bin, 1, 0);\r\n\r\n// convert amp, phase back to FFT output:\nout1, out2 = poltocar(amp, phase);",
									"fontname" : "Arial",
