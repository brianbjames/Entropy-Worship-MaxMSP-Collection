								"box" : 								{
									"code" : "Buffer loop;\r\nHistory recbar(-1);\r\nphase = in1;\r\nsrc = in2;\r\narm = in3;\r\n\r\n// get a trigger when phasor loops:\r\ntrig = (delta(phase) < 0);\r\n// bar = number of triggers received:\r\nbar = accum(trig);\r\n// idx is sample-count, reset at bar start:\r\nidx = accum(1, trig);\r\n\r\n// arm sets a new recording bar:\r\nif (arm) {\r\n\trecbar = bar + 1;\r\n}\r\n// is this the recording bar?\r\nrecording = (recbar == bar);\r\nif (recording) {\r\n\t// conditional buffer writing:\r\n\tpoke(loop, src, idx, 0);\r\n}\r\n\r\ns = phase * samplerate;\r\nout1 = sample(loop, s, index=\"samples\", interp=\"spline\");\r\nout2 = recording;",
