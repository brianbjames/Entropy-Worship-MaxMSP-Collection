, 			{
				"box" : 				{
					"maxclass" : "comment",
					"text" : "There currently isn't a dedicated erode\/dilate object for Jitter for growing or shrinking a bit mask, but these operations can be implemented using \"jit.convolve\" and jit.op @op >\". In this example, we use a 3x3 kernel where each cell is 1\/9 (box averaging filter) then use a high value like 0.95 to test against to dilate, use a low value like 0.05 to test against to erode. Larger and\/ or more interesting kernels could be used here in place of the 3x3 box averaging filter. This patch could also be made more efficient by converting the 4 plane char data to single plane char data.",
					"linecount" : 8,
					"fontsize" : 10.0,
					"patching_rect" : [ 256.0, 17.0, 388.0, 113.0 ],
					"numinlets" : 1,
					"fontname" : "Arial",
					"numoutlets" : 0,
					"id" : "obj-25"
				}

			}
, 			{
				"box" : 				{
					"maxclass" : "comment",
					"text" : "now click this button to grow\/shrink the mask. clicking multiple times will perform multiple erode\/dilate operations because of the feedback in the network below.",
					"linecount" : 4,
					"fontsize" : 10.0,
					"patching_rect" : [ 200.0, 162.0, 221.0, 60.0 ],
					"numinlets" : 1,
					"fontname" : "Arial",
					"numoutlets" : 0,
					"id" : "obj-24"
				}

			}
, 			{
				"box" : 				{
