					"numinlets" : 1,
					"numoutlets" : 0,
					"patching_rect" : [ 21.0, 109.0, 196.0, 108.0 ],
					"text" : "The send and receive objects are one-way. One part of the patch controls, and another part of the patch is controlled. However, it can be quite useful to share information using a two-way system.",
					"textcolor" : [ 0.501961, 0.501961, 0.501961, 1.0 ]
				}

